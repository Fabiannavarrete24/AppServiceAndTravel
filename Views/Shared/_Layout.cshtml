<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - AppServiceAndTravel</title>
    <link rel="stylesheet" href="~/css/root.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/AppServiceAndTravel.styles.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/Style.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link href="~/lib/datatables/datatables.css" rel="stylesheet" />
    <link href="~/lib/datatables/datatables.min.css" rel="stylesheet" />
    <link href="~/lib/fontawesome/css/all.css" rel="stylesheet" />
    <link href="~/lib/fontawesome/css/all.min.css" rel="stylesheet" />
    <link href="~/lib/select2/css/select2-bootstrap.css" rel="stylesheet" />
    <link href="~/lib/select2/css/select2-bootstrap.min.css" rel="stylesheet" />
    @await RenderSectionAsync("Styles", required: false)
    <style>
     
    </style>    
</head>
<body>
<div id="globalLoader" class="loader-overlay d-none">
    <div class="loader-box">
        <div class="spinner-border" role="status"></div>
        <span class="ms-2">Cargando...</span>
    </div>
</div>
@if (User.Identity?.IsAuthenticated == true)
{
        <partial name="_Sidebar" />
    <div id="main-wrapper">

        <div id="topbar">
            <button class="btn btn-sm me-3 d-lg-none" onclick="$('#sidebar').addClass('open');">
                <i class="fa-solid fa-bars fs-5"></i>
            </button>
            <div class="flex-grow-1">
                <div class="topbar-title">@(ViewData["Title"] ?? "Dashboard")</div>
                @if (ViewData["Breadcrumb"] != null)
                {
                    <div class="topbar-breadcrumb">@ViewData["Breadcrumb"]</div>
                }
            </div>
            <div class="d-flex align-items-center gap-3">
                <span class="topbar-breadcrumb d-none d-md-block">@User.Identity?.Name</span>
                <div class="user-avatar">@(User.Identity?.Name?.Substring(0,1).ToUpper() ?? "U")</div>
            </div>
        </div>

        <div id="page-content">
            @if (TempData["Success"] != null)
            {
                <div class="alert alert-success alert-dismissible fade show d-flex align-items-center gap-2 mb-4" Rol="alert">
                    <i class="bi bi-check-circle-fill"></i>
                    @TempData["Success"]
                    <button type="button" class="btn-close ms-auto" data-bs-dismiss="alert"></button>
                </div>
            }
            @if (TempData["Error"] != null)
            {
                <div class="alert alert-danger alert-dismissible fade show d-flex align-items-center gap-2 mb-4" Rol="alert">
                    <i class="bi bi-exclamation-triangle-fill"></i>
                    @TempData["Error"]
                    <button type="button" class="btn-close ms-auto" data-bs-dismiss="alert"></button>
                </div>
            }
            @if (TempData["Warning"] != null)
            {
                <div class="alert alert-warning alert-dismissible fade show d-flex align-items-center gap-2 mb-4" Rol="alert">
                    <i class="bi bi-exclamation-circle-fill"></i>
                    @TempData["Warning"]
                    <button type="button" class="btn-close ms-auto" data-bs-dismiss="alert"></button>
                </div>
            }

            @RenderBody()
        </div>
    </div>
}
else
{
    <div class="min-vh-100 d-flex flex-column">
        @RenderBody()
    </div>
}
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/jquery-validation/dist/jquery.validate.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/lib/datatables/datatables.js"></script>
    <script src="~/lib/datatables/datatables.min.js"></script>
    <script src="~/lib/sweetalert2/sweetalert.js"></script>
    <script src="~/lib/select2/js/select2.full.js"></script>
    <script src="~/lib/select2/js/select2.full.min.js"></script>
    <script src="~/lib/select2/js/select2.js"></script>
    <script src="~/lib/select2/js/select2.min.js"></script>
    <script src="~/lib/fontawesome/js/all.js"></script>
    <script src="~/lib/fontawesome/js/all.min.js"></script>
    <script src="~/lib/moment/moment-with-locales.js"></script>
    <script src="~/lib/moment/locale/es-us.js"></script>
    <script src="~/js/functions.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
@await RenderSectionAsync("Scripts", required: false)
    <script>
        function showLoader() {
            $("#globalLoader").removeClass("d-none");
        }

        function hideLoader() {
            $("#globalLoader").addClass("d-none");
        }
    </script>
    <script>

        $(document).ready(function (){
            let menu = sessionStorage.getItem("app_menu");

            if (menu) {
                renderMenu(JSON.parse(menu));
                return;
            }

            loadMenu();
        });
        
        $(".loadmenu").click(function(){
        loadMenu();
        });

        function loadMenu() {

            $.ajax({
                url:'/Helps/MenuNavegacion',
                type: "GET",
                beforeSend: function () {
                    showLoader();
                },
                success: function (response) {
                    console.log(response);
                    sessionStorage.setItem(
                        "app_menu",
                        JSON.stringify(response.data)
                    );

                    renderMenu(response.data);
                },
                error: function (error) {
                    console.log(error)
                },
                complete: function () {
                    hideLoader();
                }
            });
        }

        function renderMenu(data) {

            const container = $("#sidebarMenuContainer");

            container.html("");

            let html = "";

            data.forEach(menu => {
                html += renderMenuItem(menu);
            });

            container.append(html);
        }

        function renderMenuItem(menu, level = 0) {

            const tieneHijos = menu.hijos && menu.hijos.length > 0;

            let url = "#";

            if (menu.controlador && menu.url) {

                if (menu.area) {
                    url = `/${menu.area}/${menu.controlador}/${menu.url}`;
                } else {
                    url = `/${menu.controlador}/${menu.url}`;
                }
            }

            const icono = menu.icono ? `<i class="fa ${menu.icono} me-2"></i>` : `<i class="fa fa-circle me-2 fs-6"></i>`;

            if (tieneHijos) {

                let subMenuHtml = "";

                menu.hijos.forEach(hijo => {
                    subMenuHtml += renderMenuItem(hijo, level + 1);
                });

                return `
                    <div class="sidebar-group level-${level}">

                        <a class="sidebar-link sidebar-dropdown-toggle"
                           data-id="menu-${menu.idProceso}"
                           href="javascript:void(0)">

                            ${icono}
                            <span>${menu.proceso}</span>

                            <i class="fa fa-chevron-down ms-auto dropdown-icon"></i>
                        </a>

                        <div class="sidebar-submenu"
                             id="menu-${menu.idProceso}">

                            ${subMenuHtml}
                        </div>
                    </div>
                `;
            }

            return `
                <a href="${url}"
                   class="sidebar-link level-${level}">

                    ${icono}
                    <span>${menu.proceso}</span>
                </a>
            `;
        }
        $(document).on("click", ".sidebar-dropdown-toggle", function () {

            const id = $(this).data("id");

            $("#" + id).slideToggle(200);

            $(this).find(".dropdown-icon").toggleClass("rotate");
        });
    </script>
</body>
</html>
