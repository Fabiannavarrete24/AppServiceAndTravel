@model IEnumerable<AppServiceAndTravel.Models.Conductores>
@using AppServiceAndTravel.Models
@{ ViewData["Title"] = "Conductores"; var hoy = DateTime.Today; var alerta = hoy.AddDays(30); }

<div class="row g-3 mb-4">
@foreach(var (lbl,val,bg,color,icon) in new[]{
    ("Internos",       (int)ViewBag.Internos,    "#dbeafe","#1d4ed8","bi-person-badge"),
    ("Externos",       (int)ViewBag.Externos,    "#ede9fe","#6d28d9","bi-building"),
    ("Lic. vencidas",  (int)ViewBag.LicVencidas, "#fee2e2","#991b1b","bi-exclamation-triangle-fill"),
    ("Lic. por vencer",(int)ViewBag.LicPorVencer,"#fef3c7","#92400e","bi-clock"),
})
{
<div class="col-sm-6 col-xl-3">
  <div class="card">
    <div class="card-body d-flex align-items-center gap-3 p-3">
      <div class="rounded-3 d-flex align-items-center justify-content-center"
           style="width:42px;height:42px;background:@bg;color:@color;font-size:19px;flex-shrink:0;">
        <i class="bi @icon"></i></div>
      <div>
        <div class="text-muted" style="font-size:11px;">@lbl</div>
        <div class="fw-bold fs-5" style="color:@color;">@val</div>
      </div>
    </div>
  </div>
</div>
}
</div>

<div class="card">
  <div class="card-header bg-white py-3 px-4 d-flex flex-wrap align-items-center gap-3">
    <span class="fw-semibold flex-grow-1">Conductores</span>

    <div class="btn-group btn-group-sm">
      <a href="@Url.Action("Index")" class="btn @(ViewBag.Tipo==null?"btn-dark":"btn-outline-secondary") rounded-start-3">Todos</a>
      <a href="@Url.Action("Index",new{tipo=TipoProveedor.Interno})"
         class="btn @(ViewBag.Tipo?.ToString()=="Interno"?"btn-primary":"btn-outline-secondary")">Internos</a>
      <a href="@Url.Action("Index",new{tipo=TipoProveedor.Externo})"
         class="btn @(ViewBag.Tipo?.ToString()=="Externo"?"btn-purple":"btn-outline-secondary") rounded-end-3"
         style="@(ViewBag.Tipo?.ToString()=="Externo"?"background:#7c3aed;color:#fff;border-color:#7c3aed;":"")">Externos</a>
    </div>

    <form method="get" class="d-flex gap-2">
      @if(ViewBag.Tipo!=null){<input type="hidden" name="tipo" value="@ViewBag.Tipo"/>}
      <input type="search" name="q" value="@ViewBag.Q" class="form-control form-control-sm rounded-3"
             placeholder="Nombre o cédula…" style="min-width:170px;"/>
      <button class="btn btn-sm btn-outline-primary rounded-3"><i class="bi bi-search"></i></button>
    </form>

    @if(User.IsInRole("Administrador")||User.IsInRole("Coordinador")||User.IsInRole("RHManager"))
    {
    <a asp-area="RH" asp-controller="Conductor" asp-action="Create"
       class="btn btn-primary btn-sm rounded-3">
      <i class="bi bi-person-plus me-1"></i>Nuevo conductor
    </a>
    }
  </div>

  <div class="card-body p-0">
  @if(!Model.Any())
  {
    <div class="text-center py-5 text-muted">
      <i class="bi bi-person-badge" style="font-size:42px;opacity:.25;"></i>
      <p class="mt-2">No hay conductores.</p>
    </div>
  }
  else
  {
  <div class="table-responsive">
    <table class="table table-hover mb-0 align-middle">
      <thead>
        <tr>
          <th class="ps-4">Conductor</th>
          <th>Cédula</th>
          <th>Licencia</th>
          <th>Tipo</th>
          <th>Empresa ext.</th>
          <th>Estado lic.</th>
          <th>Activo</th>
          <th class="text-end pe-4">Acciones</th>
        </tr>
      </thead>
      <tbody>
      @foreach(var c in Model)
      {
        var licCss = c.FechaVencimientoLicencia < hoy
            ? "background:#fee2e2;color:#991b1b;"
            : c.FechaVencimientoLicencia <= alerta
                ? "background:#fef3c7;color:#92400e;"
                : "background:#d1fae5;color:#065f46;";

        <tr>
          <td class="ps-4">
            <div class="d-flex align-items-center gap-3">
              <div class="rounded-circle fw-bold d-flex align-items-center justify-content-center"
                   style="width:36px;height:36px;background:var(--cp);color:#fff;font-size:14px;flex-shrink:0;">
                @c.NombreCompleto.Substring(0,1).ToUpper()
              </div>
              <div>
                <div class="fw-semibold small">@c.NombreCompleto</div>

              </div>
            </div>
          </td>
          <td class="small">@c.Cedula</td>
          <td>
            <div class="small fw-semibold">@c.NumeroLicencia</div>
            <span class="badge rounded-pill px-2" style="background:#dbeafe;color:#1e40af;font-size:10px;">@c.CategoriaLicencia</span>
          </td>
          <td>
            <span class="badge rounded-pill px-2 py-1" style="font-size:11px;@(c.EsExterno?"background:#ede9fe;color:#6d28d9;":"background:#dbeafe;color:#1e40af;")">
              @c.TipoProveedor
            </span>
          </td>
          <td class="small text-muted">@(c.EsExterno ? (c.EmpresaExterna ?? "—") : "—")</td>
          <td>
            <span class="badge rounded-pill px-2 py-1" style="font-size:11px;@licCss"
                  title="Vence: @c.FechaVencimientoLicencia.ToString("dd/MM/yyyy")">
              @(c.FechaVencimientoLicencia < hoy ? "Vencida" : c.FechaVencimientoLicencia <= alerta ? "Por vencer" : "Vigente")
            </span>
          </td>
          <td>
            <span class="badge rounded-pill px-3 py-1" style="@(c.Activo?"background:#d1fae5;color:#065f46;":"background:#fee2e2;color:#991b1b;")">
              @(c.Activo?"Sí":"No")
            </span>
          </td>
          <td class="text-end pe-4">
            <div class="d-flex justify-content-end gap-1">
              <a asp-area="RH" asp-controller="Conductor" asp-action="Details" asp-route-id="@c.idConductor"
                 class="btn btn-sm btn-outline-secondary rounded-3"><i class="bi bi-eye"></i></a>
              @if(User.IsInRole("Administrador")||User.IsInRole("Coordinador")||User.IsInRole("RHManager"))
              {
              <a asp-area="RH" asp-controller="Conductor" asp-action="Edit" asp-route-id="@c.idConductor"
                 class="btn btn-sm btn-outline-primary rounded-3"><i class="bi bi-pencil"></i></a>
              <form asp-area="RH" asp-controller="Conductor" asp-action="ToggleActivo" asp-route-id="@c.idConductor" method="post">
                @Html.AntiForgeryToken()
                <button type="submit" class="btn btn-sm rounded-3"
                        style="@(c.Activo?"border:1px solid #f59e0b;color:#92400e;":"border:1px solid #16a34a;color:#065f46;")"
                        title="@(c.Activo?"Desactivar":"Activar")">
                  <i class="bi @(c.Activo?"bi-person-dash":"bi-person-check")"></i>
                </button>
              </form>
              }
            </div>
          </td>
        </tr>
      }
      </tbody>
    </table>
  </div>
  }
  </div>

  @if((int)ViewBag.TotalPag > 1)
  {
  <div class="card-footer bg-white border-0 d-flex justify-content-between py-3 px-4">
    <small class="text-muted">@ViewBag.Total conductores</small>
    <nav><ul class="pagination pagination-sm mb-0">
      @for(int p=1;p<=(int)ViewBag.TotalPag;p++)
      {<li class="page-item @(p==(int)ViewBag.P?"active":"")">
        <a class="page-link" href="@Url.Action("Index",new{q=ViewBag.Q,p})">@p</a></li>}
    </ul></nav>
  </div>
  }
</div>
