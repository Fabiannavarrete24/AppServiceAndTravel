@model IEnumerable<AppServiceAndTravel.Models.Servicios>
@using AppServiceAndTravel.Models
@{
    ViewData["Title"] = "Servicios";
    string SrvCss(EstadoServicio e) => e switch {
        EstadoServicio.Programado => "background:#dbeafe;color:#1e40af;",
        EstadoServicio.EnCurso    => "background:#fef3c7;color:#92400e;",
        EstadoServicio.Completado => "background:#d1fae5;color:#065f46;",
        EstadoServicio.Cancelado  => "background:#f1f5f9;color:#475569;",
        _ => ""
    };
}

<div class="row g-3 mb-4">
@foreach(var (lbl,val,bg,color,icon) in new[]{
    ("Total",       (int)ViewBag.Total,       "#dbeafe","#1d4ed8","bi-calendar-check"),
    ("Programados", (int)ViewBag.Programados, "#dbeafe","#1e40af","bi-calendar-plus"),
    ("En curso",    (int)ViewBag.EnCurso,     "#fef3c7","#92400e","bi-truck"),
    ("Completados", (int)ViewBag.Completados, "#d1fae5","#065f46","bi-check-circle-fill"),
    ("Cancelados",  (int)ViewBag.Cancelados,  "#fee2e2","#991b1b","bi-x-circle"),
})
{
<div class="col-sm-6 col-xl">
  <div class="card">
    <div class="card-body d-flex align-items-center gap-3 p-3">
      <div class="rounded-3 d-flex align-items-center justify-content-center"
           style="width:42px;height:42px;background:@bg;color:@color;font-size:19px;flex-shrink:0;">
        <i class="bi @icon"></i></div>
      <div>
        <div class="text-muted" style="font-size:11px;">@lbl</div>
        <div class="fw-bold fs-5" style="color:@color;">@val</div>
      </div>
    </div>
  </div>
</div>
}
</div>

<div class="card">
  <div class="card-header bg-white py-3 px-4 d-flex flex-wrap align-items-center gap-3">
    <span class="fw-semibold flex-grow-1">Gestión de servicios</span>

    <div class="btn-group btn-group-sm">
      <a href="@Url.Action("Index")" class="btn @(ViewBag.Estado==null?"btn-dark":"btn-outline-secondary") rounded-start-3">Todos</a>
      @foreach(EstadoServicio est in Enum.GetValues(typeof(EstadoServicio)))
      {
        var active = ViewBag.Estado?.ToString() == est.ToString();
        var btnCls = est switch {
          EstadoServicio.Programado => active ? "btn-primary"   : "btn-outline-secondary",
          EstadoServicio.EnCurso    => active ? "btn-warning"   : "btn-outline-secondary",
          EstadoServicio.Completado => active ? "btn-success"   : "btn-outline-secondary",
          EstadoServicio.Cancelado  => active ? "btn-secondary" : "btn-outline-secondary",
          _ => "btn-outline-secondary"
        };
        <a href="@Url.Action("Index",new{estado=est})" class="btn @btnCls @(est==EstadoServicio.Cancelado?"rounded-end-3":"")">@est</a>
      }
    </div>

    <form method="get" class="d-flex gap-2">
      @if(ViewBag.Estado!=null){<input type="hidden" name="estado" value="@ViewBag.Estado"/>}
      <input type="search" name="q" value="@ViewBag.Q" class="form-control form-control-sm rounded-3"
             placeholder="Buscar…" style="min-width:160px;"/>
      <button class="btn btn-sm btn-outline-primary rounded-3"><i class="bi bi-search"></i></button>
    </form>

    @if(User.IsInRole("Administrador")||User.IsInRole("Coordinador")||User.IsInRole("OperacionesManager"))
    {
    <a asp-area="Operaciones" asp-controller="Servicio" asp-action="Create"
       class="btn btn-primary btn-sm rounded-3"><i class="bi bi-plus-lg me-1"></i>Nuevo servicio</a>
    }
  </div>

  <div class="card-body p-0">
  @if(!Model.Any())
  {
    <div class="text-center py-5 text-muted">
      <i class="bi bi-truck" style="font-size:42px;opacity:.25;"></i>
      <p class="mt-2">No hay servicios.</p>
    </div>
  }
  else
  {
  <div class="table-responsive">
    <table class="table table-hover mb-0 align-middle">
      <thead><tr>
        <th class="ps-4">N°</th><th>Cliente</th><th>Ruta</th>
        <th>Fecha</th><th>Recurso</th><th>Estado</th>
        <th>Notif.</th><th class="text-end pe-4">Acciones</th>
      </tr></thead>
      <tbody>
      @foreach(var s in Model)
      {
        <tr>
          <td class="ps-4 fw-semibold text-muted">#@s.idServicio.ToString("D6")</td>
          <td>
            <div class="fw-semibold small">@s.Cotizacion?.Cliente?.NombreCompleto</div>
            <div class="text-muted" style="font-size:11px;">Cot. #@s.idCotizacion.ToString("D6")</div>
          </td>
          <td class="small text-muted">
            @s.Cotizacion?.Origen <i class="bi bi-arrow-right mx-1"></i>@s.Cotizacion?.Destino
          </td>
          <td>
            <div class="small fw-semibold">@s.FechaServicio.ToString("dd/MM/yyyy")</div>
            <div class="text-muted" style="font-size:11px;">@s.FechaServicio.ToString("HH:mm")</div>
          </td>
          <td>
            @if(s.UsaRecursoExterno)
            {
              <span class="badge rounded-pill px-2 py-1" style="background:#ede9fe;color:#6d28d9;font-size:11px;">
                <i class="bi bi-building me-1"></i>@(s.ProveedorExterno?.RazonSocial ?? s.VehiculoExternoPlaca ?? "Externo")
              </span>
            }
            else
            {
              <div class="small fw-semibold">@s.Vehiculo?.Placa</div>
              <div class="text-muted" style="font-size:11px;">@s.Conductor?.NombreCompleto</div>
            }
          </td>
          <td><span class="badge rounded-pill px-3 py-2" style="@SrvCss(s.Estado)">@s.Estado</span></td>
          <td>
            <div class="d-flex gap-1">
              <i class="bi bi-envelope text-success opacity-50" style="font-size:14px;"
                 title="Email enviado":"Email no enviado"></i>
              <i class="bi bi-whatsapp text-muted opacity-50")" style="font-size:14px;"
                 title="WA no enviado"></i>
            </div>
          </td>
          <td class="text-end pe-4">
            <a asp-area="Operaciones" asp-controller="Servicio" asp-action="Details" asp-route-id="@s.idServicio"
               class="btn btn-sm btn-outline-secondary rounded-3"><i class="bi bi-eye"></i></a>
          </td>
        </tr>
      }
      </tbody>
    </table>
  </div>
  }
  </div>
  @if((int)ViewBag.TotalPag>1)
  {
  <div class="card-footer bg-white border-0 d-flex justify-content-between py-3 px-4">
    <small class="text-muted">@ViewBag.Total servicios</small>
    <nav><ul class="pagination pagination-sm mb-0">
      @for(int pg=1;pg<=(int)ViewBag.TotalPag;pg++)
      {<li class="page-item @(pg==(int)ViewBag.P?"active":"")">
        <a class="page-link" href="@Url.Action("Index",new{q=ViewBag.Q,estado=ViewBag.Estado,p=pg})">@pg</a></li>}
    </ul></nav>
  </div>
  }
</div>
