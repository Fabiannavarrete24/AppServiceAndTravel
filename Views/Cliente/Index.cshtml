@model IEnumerable<AppServiceAndTravel.Models.Cliente>

@{
    ViewData["Title"] = "Clientes";
    ViewData["Breadcrumb"] = "Gestión de clientes";
}

<!-- Stats -->
<div class="row g-3 mb-4">

    <div class="col-md-6 col-xl-3">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body d-flex gap-3 align-items-center">
                <div class="rounded-circle d-flex align-items-center justify-content-center"
                     style="width:48px;height:48px;background:#dbeafe;color:#1d4ed8;">
                    <i class="bi bi-people-fill"></i>
                </div>
                <div>
                    <small class="text-muted">Total clientes</small>
                    <div class="fw-bold fs-4">@ViewBag.Total</div>
                </div>
            </div>
        </div>
    </div>

    <div class="col-md-6 col-xl-3">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body d-flex gap-3 align-items-center">
                <div class="rounded-circle d-flex align-items-center justify-content-center"
                     style="width:48px;height:48px;background:#d1fae5;color:#065f46;">
                    <i class="bi bi-person-check-fill"></i>
                </div>
                <div>
                    <small class="text-muted">Clientes activos</small>
                    <div class="fw-bold fs-4">@ViewBag.TotalActivos</div>
                </div>
            </div>
        </div>
    </div>

</div>

<!-- Tabla -->
<div class="card border-0 shadow-sm">

    <div class="card-header bg-white py-3 d-flex flex-wrap gap-3 align-items-center">

        <span class="fw-semibold flex-grow-1">
            Clientes registrados
        </span>

        <!-- Buscar -->
        <form method="get" class="d-flex gap-2">

            <input type="search"
                   name="busqueda"
                   value="@ViewBag.Busqueda"
                   class="form-control form-control-sm"
                   placeholder="Buscar cliente..."
                   style="min-width:240px;" />

            <button type="submit" class="btn btn-sm btn-outline-primary">
                <i class="bi bi-search"></i>
            </button>

        </form>

        @if (User.IsInRole("Administrador") ||
                User.IsInRole("Coordinador") ||
                User.IsInRole("Operador"))
        {
            <a asp-action="Create" class="btn btn-primary btn-sm">
                <i class="bi bi-plus-lg me-1"></i>Nuevo
            </a>
        }

    </div>

    <div class="card-body p-0">

        @if (Model == null || !Model.Any())
        {
            <div class="text-center py-5 text-muted">
                <i class="bi bi-inbox" style="font-size:40px;opacity:.3;"></i>
                <p class="mt-2 mb-0">No hay clientes registrados.</p>
            </div>
        }
        else
        {
            <div class="table-responsive">

                <table class="table table-hover mb-0">

                    <thead>
                        <tr>
                            <th class="ps-4">Cliente</th>
                            <th>NIT / Cédula</th>
                            <th>correo</th>
                            <th>Teléfono</th>
                            <th>Estado</th>
                            <th>Registro</th>
                            <th class="text-end pe-4">Acciones</th>
                        </tr>
                    </thead>

                    <tbody>

                        @foreach (var c in Model)
                        {
                            <tr>

                                <td class="ps-4">
                                    <div class="fw-semibold">@c.NombreCompleto</div>
                                    <small class="text-muted">@c.Direccion</small>
                                </td>

                                <td>@c.NitCedula</td>

                                <td>@c.correo</td>

                                <td>@c.Telefono</td>

                                <td>
                                    @if (c.Activo)
                                    {
                                        <span class="badge bg-success">Activo</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-danger">Inactivo</span>
                                    }
                                </td>

                                <td>
                                    <small class="text-muted">
                                        @c.FechaCreacion.ToString("dd/MM/yyyy")
                                    </small>
                                </td>

                                <td class="text-end pe-4">

                                    <div class="d-flex justify-content-end gap-1">

                                        <a asp-action="Details"
                                           asp-route-id="@c.Id"
                                           class="btn btn-sm btn-outline-secondary">
                                            <i class="bi bi-eye"></i>
                                        </a>

                                        @if (User.IsInRole("Administrador") ||
                                                                        User.IsInRole("Coordinador") ||
                                                                        User.IsInRole("Operador"))
                                        {
                                            <a asp-action="Edit"
                                               asp-route-id="@c.Id"
                                               class="btn btn-sm btn-outline-primary">
                                                <i class="bi bi-pencil"></i>
                                            </a>
                                        }

                                        @if (User.IsInRole("Administrador"))
                                        {
                                            <form asp-action="Delete"
                                                  asp-route-id="@c.Id"
                                                  method="post"
                                                  onsubmit="return confirmada('¿Eliminar cliente?')">

                                                @Html.AntiForgeryToken()

                                                <button class="btn btn-sm btn-outline-danger">
                                                    <i class="bi bi-trash"></i>
                                                </button>

                                            </form>
                                        }

                                    </div>

                                </td>

                            </tr>
                        }

                    </tbody>

                </table>

            </div>
        }

    </div>

    <!-- Paginación -->
    @if ((int)ViewBag.TotalPaginas > 1)
    {
        <div class="card-footer bg-white py-3 d-flex justify-content-between align-items-center">

            <small class="text-muted">
                Mostrando
                @((((int)ViewBag.Pagina - 1) * 10) + 1)
                –
                @Math.Min((int)ViewBag.Pagina * 10, (int)ViewBag.Total)
                de
                @ViewBag.Total
            </small>

            <nav>
                <ul class="pagination pagination-sm mb-0">

                    <li class="page-item @((int)ViewBag.Pagina == 1 ? "disabled" : "")">
                        <a class="page-link"
                           href="@Url.Action("Index", new { p = (int)ViewBag.Pagina - 1, busqueda = ViewBag.Busqueda })">
                            ‹
                        </a>
                    </li>

                    @for (int i = 1; i <= (int)ViewBag.TotalPaginas; i++)
                    {
                        <li class="page-item @(i == (int)ViewBag.Pagina ? "activo" : "")">
                            <a class="page-link"
                               href="@Url.Action("Index", new { p = i, busqueda = ViewBag.Busqueda })">
                                @i
                            </a>
                        </li>
                    }

                    <li class="page-item @((int)ViewBag.Pagina == (int)ViewBag.TotalPaginas ? "disabled" : "")">
                        <a class="page-link"
                           href="@Url.Action("Index", new { p = (int)ViewBag.Pagina + 1, busqueda = ViewBag.Busqueda })">
                            ›
                        </a>
                    </li>

                </ul>
            </nav>

        </div>
    }

</div>