@using AppServiceAndTravel.Areas.Comercial.Models
@model Clientes

@{
    ViewData["Title"] = "Editar Cliente";
    ViewData["Breadcrumb"] = "Clientes / Editar";
}
<div class="row justify-content-center">

    <div class="col-lg-8">

        <div class="card border-0 shadow-sm rounded-4">

            <div class="card-header bg-white border-0 pt-4 px-4 pb-0">

                <h5 class="fw-semibold mb-1">
                    <i class="bi bi-person-plus me-2 text-primary"></i>
                    Registrar cliente
                </h5>

                <small class="text-muted">
                    Complete la información del cliente
                </small>

            </div>

            <div class="card-body p-4">

                <form asp-action="Create" method="post">
                    <input type="hidden" asp-for="idCliente" />
                    @Html.AntiForgeryToken()

                    <div asp-validation-summary="ModelOnly"
                         class="alert alert-danger"></div>

                    <div class="row g-3">

                        <div class="col-md-6">
                            <label asp-for="RazonSocial" class="form-label"></label>
                            <input asp-for="RazonSocial" class="form-control" />
                            <span asp-validation-for="RazonSocial" class="text-danger"></span>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="NitCedula" class="form-label"></label>
                            <input asp-for="NitCedula" class="form-control" />
                            <span asp-validation-for="NitCedula" class="text-danger"></span>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="Telefono" class="form-label"></label>
                            <input asp-for="Telefono" class="form-control" />
                        </div>

                        <div class="col-md-6">
                            <label asp-for="Correo" class="form-label"></label>
                            <input asp-for="Correo" class="form-control" />
                        </div>

                        <div class="col-12">
                            <label asp-for="Direccion" class="form-label"></label>
                            <textarea asp-for="Direccion"
                                      class="form-control"
                                      rows="3"></textarea>
                        </div>

                        <div class="col-12">
                            <div class="form-check">
                                <input asp-for="Activo" class="form-check-input" />
                                <label asp-for="Activo" class="form-check-label"></label>
                            </div>
                        </div>

                    </div>

                    <div class="d-flex gap-2 mt-4">

                        <button class="btn btn-primary px-4">
                            <i class="bi bi-save me-1"></i>
                            Guardar
                        </button>

                        <a asp-action="Index"
                           class="btn btn-outline-secondary">
                            Cancelar
                        </a>

                    </div>

                </form>

            </div>

        </div>

    </div>

</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}