@{ ViewData["Title"] = "Editar Usuario"; }

<div class="row g-4">
  <div class="col-lg-8">
    <div class="card">
      <div class="card-header bg-white py-3 px-4 d-flex align-items-center gap-2">
        <div class="rounded-3 d-flex align-items-center justify-content-center"
             style="width:36px;height:36px;background:#dbeafe;font-size:18px;color:#1d4ed8;">
          <i class="bi bi-person-gear"></i>
        </div>
        <div>
          <h5 class="mb-0 fw-semibold">@ViewData["Title"]</h5>
          <small class="text-muted"></small>
        </div>
      </div>
      <div class="card-body px-4 py-4">
        <form asp-area="Admin" asp-controller="Usuarios" asp-action="Edit" method="post">
          @Html.AntiForgeryToken()
          <input type="hidden"  />
          <input type="hidden"/>
          <div asp-validation-summary="ModelOnly" class="alert alert-danger rounded-3 py-2 small"></div>

          <h6 class="fw-semibold small text-uppercase text-muted mb-3">Datos personales</h6>
          <div class="row g-3 mb-4">
            <div class="col-md-7">
              <label class="form-label fw-semibold small">Nombre completo *</label>
              <input class="form-control rounded-3" required />
              <span class="text-danger small"></span>
            </div>
            <div class="col-md-5">
              <label class="form-label fw-semibold small">Cargo</label>
              <input class="form-control rounded-3" />
            </div>
            <div class="col-md-6">
              <label class="form-label fw-semibold small">Email</label>
              <input type="email" value="@Model.Email" class="form-control rounded-3" readonly />
              <div class="form-text">El email no se puede cambiar.</div>
            </div>
            <div class="col-md-6">
              <label class="form-label fw-semibold small">Teléfono</label>
              <input  class="form-control rounded-3" />
            </div>
            <div class="col-12">
              <div class="form-check form-switch">
                <input class="form-check-input" type="checkbox" />
                <label class="form-check-label fw-semibold small">Usuario activo</label>
              </div>
            </div>
          </div>

          <h6 class="fw-semibold small text-uppercase text-muted mb-3">Cambiar contraseña (opcional)</h6>
          <div class="row g-3 mb-4">
            <div class="col-md-6">
              <label class="form-label fw-semibold small">Nueva contraseña</label>
              <div class="input-group">
                <input type="password" class="form-control rounded-start-3"
                       id="pwdNuevo" placeholder="Dejar vacío para no cambiar" />
                <button type="button" class="btn btn-outline-secondary rounded-end-3"
                        onclick="togglePwd('pwdNuevo','icoNuevo')">
                  <i class="bi bi-eye" id="icoNuevo"></i>
                </button>
              </div>
              <span class="text-danger small"></span>
            </div>
          </div>

          <h6 class="fw-semibold small text-uppercase text-muted mb-3">Roles y permisos</h6>
          <div class="row g-2 mb-4">
            @foreach(var rol in (List<string>)ViewBag.Roles)
            {
              var estaSeleccionado = Model.RolesSeleccionados.Contains(rol);
              var (rolBg,rolColor) = rol switch {
                "Administrador"        => ("#fee2e2","#991b1b"),
                "Aprobador"            => ("#fef3c7","#92400e"),
                "Coordinador"          => ("#dbeafe","#1e40af"),
                "Operador"             => ("#d1fae5","#065f46"),
                "ComercialManager"     => ("#fce7f3","#9d174d"),
                "OperacionesManager"   => ("#ccfbf1","#0f766e"),
                "ContabilidadManager"  => ("#fef9c3","#854d0e"),
                "RHManager"            => ("#ede9fe","#6d28d9"),
                _                      => ("#f1f5f9","#475569")
              };
              <div class="col-md-4 col-6">
                <div class="form-check p-0">
                  <label class="d-flex align-items-center gap-2 p-2 rounded-3"
                         style="border:1.5px solid @(estaSeleccionado?"var(--cp)":"#e2e8f0");cursor:pointer;
                                background:@(estaSeleccionado?"color-mix(in srgb, var(--cp) 5%, transparent)":"transparent");">
                    <input type="checkbox" name="RolesSeleccionados" value="@rol"
                           class="form-check-input mt-0" @(estaSeleccionado?"checked":"") />
                    <span class="badge rounded-pill px-3 py-2"
                          style="background:@rolBg;color:@rolColor;font-size:12px;">@rol</span>
                  </label>
                </div>
              </div>
            }
          </div>

          <div class="d-flex gap-3 pt-2">
            <button type="submit" class="btn btn-primary px-4 rounded-3">
              <i class="bi bi-save me-2"></i>Guardar cambios
            </button>
            <a asp-area="Admin" asp-controller="Usuarios" asp-action="Index"
               class="btn btn-outline-secondary rounded-3">Cancelar</a>
          </div>
        </form>
      </div>
    </div>
  </div>
</div>

@section Scripts {
<partial name="_ValidationScriptsPartial" />
<script>
function togglePwd(id, iconId) {
    const i = document.getElementById(id); const ic = document.getElementById(iconId);
    i.type = i.type === 'password' ? 'text' : 'password';
    ic.className = i.type === 'password' ? 'bi bi-eye' : 'bi bi-eye-slash';
}
</script>
}
