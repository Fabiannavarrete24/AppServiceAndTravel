@model IEnumerable<AppServiceAndTravel.Models.Clientes>
@{ ViewData["Title"] = "Clientes"; }

<div class="row g-3 mb-4">
    @foreach(var (lbl,val,bg,color,icon) in new[]{
        ("Total clientes",    (int)ViewBag.Total,    "#dbeafe","#1d4ed8","bi-people"),
        ("Activos",           (int)ViewBag.Activos,  "#d1fae5","#065f46","bi-check-circle"),
        ("Inactivos",         (int)ViewBag.Inactivos,"#fee2e2","#991b1b","bi-x-circle"),
    })
    {
    <div class="col-sm-4">
        <div class="card">
            <div class="card-body d-flex align-items-center gap-3 p-3">
                <div class="rounded-3 d-flex align-items-center justify-content-center"
                     style="width:44px;height:44px;background:@bg;color:@color;font-size:20px;flex-shrink:0;">
                    <i class="bi @icon"></i>
                </div>
                <div>
                    <div class="text-muted" style="font-size:12px;">@lbl</div>
                    <div class="fw-bold fs-4" style="color:@color;">@val</div>
                </div>
            </div>
        </div>
    </div>
    }
</div>

<div class="card">
    <div class="card-header bg-white py-3 px-4 d-flex flex-wrap align-items-center gap-3">
        <span class="fw-semibold flex-grow-1">Directorio de clientes</span>
        <form method="get" class="d-flex gap-2">
            <input type="search" name="q" value="@ViewBag.Q" class="form-control form-control-sm rounded-3"
                   placeholder="Buscar…" style="min-width:180px;" />
            <div class="form-check form-switch ms-2 d-flex align-items-center mb-0">
                <input class="form-check-input" type="checkbox" name="soloActivos" value="true"
                       id="chkActivos" @(ViewBag.SoloActivos==true?"checked":"")
                       onchange="this.form.submit()" />
                <label class="form-check-label small ms-2" for="chkActivos">Solo activos</label>
            </div>
            <button class="btn btn-sm btn-outline-primary rounded-3"><i class="bi bi-search"></i></button>
        </form>
        @if(User.IsInRole("Administrador")||User.IsInRole("Coordinador")||User.IsInRole("Operador")||User.IsInRole("ComercialManager"))
        {
        <a asp-area="Comercial" asp-controller="Cliente" asp-action="Create"
           class="btn btn-primary btn-sm rounded-3">
            <i class="bi bi-person-plus me-1"></i>Nuevo cliente
        </a>
        }
    </div>

    <div class="card-body p-0">
        @if(!Model.Any())
        {
            <div class="text-center py-5 text-muted">
                <i class="bi bi-people" style="font-size:42px;opacity:.25;"></i>
                <p class="mt-2">No hay clientes registrados.</p>
            </div>
        }
        else
        {
        <div class="table-responsive">
          <table class="table table-hover mb-0 align-middle">
            <thead>
              <tr>
                <th class="ps-4">Cliente</th>
                <th>NIT / Cédula</th>
                <th>Contacto</th>
                <th>Ciudad</th>
                <th>Cotizaciones</th>
                <th>Estado</th>
                <th class="text-end pe-4">Acciones</th>
              </tr>
            </thead>
            <tbody>
            @foreach(var c in Model)
            {
              <tr>
                <td class="ps-4">
                  <div class="d-flex align-items-center gap-3">
                    <div class="rounded-circle fw-bold d-flex align-items-center justify-content-center"
                         style="width:38px;height:38px;background:var(--cp);color:#fff;font-size:15px;flex-shrink:0;">
                      @c.NombreCompleto.Substring(0,1).ToUpper()
                    </div>
                    <div>
                      <div class="fw-semibold small">@c.NombreCompleto</div>
                      <div class="text-muted" style="font-size:12px;">Desde @c.FechaCreacion.ToString("dd/MM/yyyy")</div>
                    </div>
                  </div>
                </td>
                <td class="small">@c.NitCedula</td>
                <td>
                  <div class="small"></div>
                  <div class="text-muted" style="font-size:12px;"><i class="bi bi-telephone me-1"></i>@c.Telefono</div>
                </td>
                <td class="small text-muted">@(c.Ciudad ?? "—")</td>
                <td>
                  <span class="badge rounded-pill px-3 py-2" style="background:#dbeafe;color:#1e40af;">
                    @c.Cotizaciones.Count
                  </span>
                </td>
                <td>
                  <span class="badge rounded-pill px-3 py-2"
                        style="@(c.Activo?"background:#d1fae5;color:#065f46;":"background:#fee2e2;color:#991b1b;")">
                    @(c.Activo?"Activo":"Inactivo")
                  </span>
                </td>
                <td class="text-end pe-4">
                  <div class="d-flex justify-content-end gap-1">
                    <a asp-area="Comercial" asp-controller="Cliente" asp-action="Details" asp-route-id="@c.idCliente"
                       class="btn btn-sm btn-outline-secondary rounded-3" title="Ver"><i class="bi bi-eye"></i></a>
                    @if(User.IsInRole("Administrador")||User.IsInRole("Coordinador")||User.IsInRole("Operador")||User.IsInRole("ComercialManager"))
                    {
                    <a asp-area="Comercial" asp-controller="Cliente" asp-action="Edit" asp-route-id="@c.idCliente"
                       class="btn btn-sm btn-outline-primary rounded-3" title="Editar"><i class="bi bi-pencil"></i></a>
                    <form asp-area="Comercial" asp-controller="Cliente" asp-action="ToggleActivo"
                          asp-route-id="@c.idCliente" method="post">
                      @Html.AntiForgeryToken()
                      <button type="submit" class="btn btn-sm rounded-3"
                              style="@(c.Activo?"border:1px solid #f59e0b;color:#92400e;":"border:1px solid #16a34a;color:#065f46;")"
                              title="@(c.Activo?"Desactivar":"Activar")">
                        <i class="bi @(c.Activo?"bi-person-dash":"bi-person-check")"></i>
                      </button>
                    </form>
                    }
                  </div>
                </td>
              </tr>
            }
            </tbody>
          </table>
        </div>
        }
    </div>

    @if((int)ViewBag.TotalPag > 1)
    {
    <div class="card-footer bg-white border-0 d-flex align-items-center justify-content-between py-3 px-4">
        <small class="text-muted">@ViewBag.Total registros</small>
        <nav><ul class="pagination pagination-sm mb-0">
            @for(int p = 1; p <= (int)ViewBag.TotalPag; p++)
            {
            <li class="page-item @(p==(int)ViewBag.P?"active":"")">
                <a class="page-link" href="@Url.Action("Index", new{q=ViewBag.Q,p})">@p</a>
            </li>
            }
        </ul></nav>
    </div>
    }
</div>
