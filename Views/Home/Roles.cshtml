        <span class="badge rounded-pill" style="background:#dbeafe;color:#1e40af;">roles</span>
      </div>
      <div class="card-body p-0">
        <div class="table-responsive">
          <table class="table table-hover mb-0 align-middle">
            <thead>
              <tr>
                <th class="ps-4">Rol</th>
                <th>Tipo</th>
                <th class="text-end pe-4">Acciones</th>
              </tr>
            </thead>
            <tbody>
            @{
              var rolesProtegidos = new[]{"Administrador","Coordinador","Aprobador","Operador","Consulta"};
            }
