            </tbody>
          </table>
        </div>
      </div>
    </div>
  </div>

  <div class="col-lg-5">
    <div class="card">
      <div class="card-header bg-white py-3 px-4">
        <span class="fw-semibold"><i class="bi bi-plus-circle me-2 text-primary"></i>Crear nuevo rol</span>
      </div>
      <div class="card-body p-4">
        <form asp-area="Admin" asp-controller="Usuarios" asp-action="CrearRol" method="post">
          @Html.AntiForgeryToken()
          <div class="mb-3">
            <label class="form-label fw-semibold small">Nombre del rol</label>
            <input type="text" name="nombre" class="form-control rounded-3" required
                   placeholder="Ej: GerenteRegional" />
            <div class="form-text">Use PascalCase sin espacios. Ej: GerenteZona</div>
          </div>
          <button type="submit" class="btn btn-primary rounded-3 w-100">
            <i class="bi bi-plus-lg me-2"></i>Crear rol
          </button>
        </form>

        <hr class="my-4" />
        <h6 class="fw-semibold small mb-3"><i class="bi bi-info-circle me-2 text-primary"></i>Roles del sistema</h6>
        @foreach(var (r,d) in new[]{
          ("Administrador","Acceso total sin restricciones."),
          ("Aprobador","Aprueba o rechaza cotizaciones."),
          ("Coordinador","Gestiona servicios y flota."),
          ("Operador","Crea cotizaciones y clientes."),
          ("ComercialManager","Área comercial completa."),
          ("OperacionesManager","Área operaciones completa."),
          ("ContabilidadManager","Reportes y finanzas."),
          ("RHManager","Personal y proveedores."),
          ("Consulta","Solo lectura en todo."),
        })
        {
          <div class="d-flex gap-2 mb-2 small">
            <i class="bi bi-shield text-primary mt-1" style="flex-shrink:0;"></i>
            <span><strong>@r</strong> — @d</span>
          </div>
        }
      </div>
    </div>
  </div>
</div>
