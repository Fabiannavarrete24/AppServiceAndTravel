@{ ViewData["Title"] = "Usuarios del sistema"; }

<div class="row g-3 mb-4">
    @foreach(var (lbl,val,icon,bg,color) in new[]{
        ("Total usuarios", (int)ViewBag.TotalUsuarios, "bi-people",          "#dbeafe","#1d4ed8"),
        ("Activos",        (int)ViewBag.TotalActivos,  "bi-check-circle",    "#d1fae5","#065f46"),
        ("Inactivos",      (int)ViewBag.TotalUsuarios-(int)ViewBag.TotalActivos,"bi-x-circle","#fee2e2","#991b1b"),
        ("Roles definidos",((List<string>)ViewBag.Roles).Count,"bi-shield-check","#ede9fe","#6d28d9"),
    })
    {
    <div class="col-sm-6 col-xl-3">
        <div class="card">
            <div class="card-body d-flex align-items-center gap-3 p-3">
                <div class="rounded-3 d-flex align-items-center justify-content-center"
                     style="width:44px;height:44px;background:@bg;color:@color;font-size:20px;flex-shrink:0;">
                    <i class="bi @icon"></i>
                </div>
                <div>
                    <div class="text-muted" style="font-size:12px;">@lbl</div>
                    <div class="fw-bold fs-4" style="color:@color;">@val</div>
                </div>
            </div>
        </div>
    </div>
    }
</div>

<div class="card">
    <div class="card-header bg-white py-3 px-4 d-flex flex-wrap align-items-center gap-3">
        <span class="fw-semibold flex-grow-1">Gestión de usuarios</span>
        <form method="get" class="d-flex gap-2 flex-wrap">
            <input type="search" name="q" value="@ViewBag.Q" class="form-control form-control-sm rounded-3"
                   placeholder="Buscar nombre o email…" style="min-width:180px;" />
            <select name="rol" class="form-select form-select-sm rounded-3" style="min-width:140px;">
                <option value="">Todos los roles</option>
            </select>
            <select name="activo" class="form-select form-select-sm rounded-3" style="min-width:120px;">
                <option value="">Todos</option>
                <option value="true">Activos</option>
                <option value="false">Inactivos</option>
            </select>
            <button class="btn btn-sm btn-outline-primary rounded-3"><i class="bi bi-search"></i></button>
        </form>
        <a asp-area="Admin" asp-controller="Usuarios" asp-action="Create"
           class="btn btn-primary btn-sm rounded-3">
            <i class="bi bi-plus-lg me-1"></i>Nuevo usuario
        </a>
        <a asp-area="Admin" asp-controller="Usuarios" asp-action="Roles"
           class="btn btn-outline-secondary btn-sm rounded-3">
            <i class="bi bi-shield-check me-1"></i>Roles
        </a>
    </div>

    <div class="card-body p-0">
        @if (!Model.Any())
        {
            <div class="text-center py-5 text-muted">
                <i class="bi bi-people" style="font-size:40px;opacity:.3;"></i>
                <p class="mt-2">No hay usuarios que mostrar.</p>
            </div>
        }
        else
        {
        <div class="table-responsive">
            <table class="table table-hover mb-0 align-middle">
                <thead>
                    <tr>
                        <th class="ps-4">Usuario</th>
                        <th>Cargo</th>
                        <th>Roles</th>
                        <th>Último acceso</th>
                        <th>Estado</th>
                        <th class="text-end pe-4">Acciones</th>
                    </tr>
                </thead>
                <tbody>
                @foreach(var vm in Model)
                {
                    var u = vm.Usuario;
                    <tr>
                        <td class="ps-4">
                            <div class="d-flex align-items-center gap-3">
                                <div class="rounded-circle d-flex align-items-center justify-content-center fw-bold"
                                     style="width:38px;height:38px;background:var(--cp);color:#fff;font-size:15px;flex-shrink:0;">
                                    @(string.IsNullOrEmpty(u.Foto)
                                        ? u.NombreCompleto.Substring(0,1).ToUpper()
                                        : "")
                                    @if(!string.IsNullOrEmpty(u.Foto))
                                    { <img src="@u.Foto" class="rounded-circle w-100 h-100" style="object-fit:cover;" /> }
                                </div>
                                <div>
                                    <div class="fw-semibold small">@u.NombreCompleto</div>
                                    <div class="text-muted" style="font-size:12px;">@u.Email</div>
                                </div>
                            </div>
                        </td>
                        <td class="small text-muted">@(u.Cargo ?? "—")</td>
                        <td>
                            @foreach(var r in vm.Roles)
                            {
                                var rColor = r switch {
                                    "Administrador"     => "background:#fee2e2;color:#991b1b;",
                                    "Aprobador"         => "background:#fef3c7;color:#92400e;",
                                    "Coordinador"       => "background:#dbeafe;color:#1e40af;",
                                    "Operador"          => "background:#d1fae5;color:#065f46;",
                                    _                   => "background:#f1f5f9;color:#475569;"
                                };
                                <span class="badge rounded-pill me-1 px-2 py-1" style="font-size:11px;@rColor">@r</span>
                            }
                        </td>
                        <td class="small text-muted">
                            @(u.UltimoAcceso.HasValue ? u.UltimoAcceso.Value.ToString("dd/MM/yy HH:mm") : "Nunca")
                        </td>
                        <td>
                            <span class="badge rounded-pill px-3 py-2"
                                  style="@(u.Activo ? "background:#d1fae5;color:#065f46;" : "background:#fee2e2;color:#991b1b;")">
                                @(u.Activo ? "Activo" : "Inactivo")
                            </span>
                        </td>
                        <td class="text-end pe-4">
                            <div class="d-flex justify-content-end gap-1">
                                <a asp-area="Admin" asp-controller="Usuarios" asp-action="Edit"
                                   asp-route-id="@u.Id" class="btn btn-sm btn-outline-primary rounded-3" title="Editar">
                                    <i class="bi bi-pencil"></i>
                                </a>
                                <form asp-area="Admin" asp-controller="Usuarios"
                                      asp-action="ToggleActivo" asp-route-id="@u.Id" method="post">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-sm rounded-3"
                                            style="@(u.Activo ? "border:1px solid #ef4444;color:#ef4444;" : "border:1px solid #16a34a;color:#16a34a;")"
                                            title="@(u.Activo ? "Desactivar" : "Activar")">
                                        <i class="bi @(u.Activo ? "bi-person-x" : "bi-person-check")"></i>
                                    </button>
                                </form>
                            </div>
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
        }
    </div>
</div>
