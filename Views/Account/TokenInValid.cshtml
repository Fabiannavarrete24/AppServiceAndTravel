@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Token inválido — TransporteApp</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.css" />
    <link href="~/lib/fontawesome/css/all.min.css" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Sora:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
    <style>
    :root {
        --ink:    #0a0f1e;
        --panel:  #111827;
        --surface:#1a2236;
        --border: rgba(255,255,255,.08);
        --accent: #2563eb;
        --accent2:#3b82f6;
        --text:   #e2e8f0;
        --muted:  #64748b;
        --error:  #ef4444;
        --warn:   #f59e0b;
        --font:   'Sora', sans-serif;
    }

    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    html, body {
        min-height: 100vh;
        font-family: var(--font);
        background: var(--ink);
        display: flex;
        flex-direction: column;
        background-image:
            radial-gradient(ellipse 70% 50% at 50% -10%, rgba(239,68,68,.1) 0%, transparent 60%),
            radial-gradient(ellipse 50% 40% at 80% 80%, rgba(37,99,235,.08) 0%, transparent 50%);
    }

    /* ── Partículas sutiles ── */
    .bg-dots {
        position: fixed; inset: 0; pointer-events: none; overflow: hidden; z-index: 0;
        background-image: radial-gradient(rgba(255,255,255,.04) 1px, transparent 1px);
        background-size: 32px 32px;
    }

    /* ── Topbar mínima ── */
    .top-bar {
        position: relative; z-index: 10;
        padding: 24px 32px;
        display: flex; align-items: center; gap: 12px;
        border-bottom: 1px solid var(--border);
    }
    .top-logo-icon {
        width: 40px; height: 40px;
        background: linear-gradient(135deg, var(--accent), var(--accent2));
        border-radius: 11px;
        display: flex; align-items: center; justify-content: center;
        font-size: 18px; color: #fff;
        box-shadow: 0 6px 20px rgba(37,99,235,.3);
        flex-shrink: 0;
    }
    .top-logo-img { max-height: 36px; max-width: 150px; object-fit: contain; }
    .top-logo-name { font-size: 14px; font-weight: 700; color: var(--text); }
    .top-logo-sub  { font-size: 11px; color: var(--muted); }

    /* ── Contenido central ── */
    .page-center {
        position: relative; z-index: 10;
        flex: 1;
        display: flex; align-items: center; justify-content: center;
        padding: 32px 20px;
    }

    .token-card {
        background: var(--panel);
        border: 1px solid var(--border);
        border-radius: 24px;
        padding: 56px 48px;
        max-width: 520px; width: 100%;
        text-align: center;
        box-shadow: 0 24px 60px rgba(0,0,0,.4);
        animation: fadeUp .5s cubic-bezier(.4,0,.2,1) both;
    }
    @@keyframes fadeUp {
        from { opacity: 0; transform: translateY(28px); }
        to   { opacity: 1; transform: translateY(0); }
    }

    /* ── Icono ── */
    .token-icon-ring {
        position: relative;
        width: 96px; height: 96px;
        margin: 0 auto 32px;
        animation: popIn .55s .1s cubic-bezier(.34,1.56,.64,1) both;
    }
    @@keyframes popIn {
        from { opacity: 0; transform: scale(.5); }
        to   { opacity: 1; transform: scale(1); }
    }

    /* Anillo exterior pulsante */
    .token-icon-ring::before {
        content: '';
        position: absolute; inset: -8px;
        border-radius: 50%;
        border: 2px solid rgba(239,68,68,.2);
        animation: pulse 2.4s ease-in-out infinite;
    }
    .token-icon-ring::after {
        content: '';
        position: absolute; inset: -18px;
        border-radius: 50%;
        border: 2px solid rgba(239,68,68,.08);
        animation: pulse 2.4s .4s ease-in-out infinite;
    }
    @@keyframes pulse {
        0%, 100% { transform: scale(1);    opacity: 1; }
        50%       { transform: scale(1.12); opacity: 0; }
    }

    .token-icon-inner {
        width: 96px; height: 96px;
        background: rgba(239,68,68,.1);
        border: 1.5px solid rgba(239,68,68,.25);
        border-radius: 50%;
        display: flex; align-items: center; justify-content: center;
        font-size: 38px; color: var(--error);
    }

    /* ── Textos ── */
    .token-badge {
        display: inline-flex; align-items: center; gap: 6px;
        background: rgba(239,68,68,.1);
        border: 1px solid rgba(239,68,68,.25);
        color: #fca5a5;
        font-size: 11px; font-weight: 600;
        padding: 5px 14px; border-radius: 99px;
        text-transform: uppercase; letter-spacing: .8px;
        margin-bottom: 16px;
        animation: fadeUp .4s .2s ease both;
    }

    .token-title {
        font-size: 26px; font-weight: 700;
        color: var(--text); letter-spacing: -.4px;
        margin-bottom: 14px;
        animation: fadeUp .4s .25s ease both;
    }

    .token-desc {
        font-size: 14px; color: var(--muted);
        line-height: 1.75; margin-bottom: 8px;
        animation: fadeUp .4s .3s ease both;
    }

    /* ── Info chips ── */
    .info-chips {
        display: flex; flex-direction: column; gap: 10px;
        margin: 28px 0 32px;
        animation: fadeUp .4s .35s ease both;
    }
    .info-chip {
        display: flex; align-items: flex-start; gap: 12px;
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: 12px;
        padding: 12px 16px;
        text-align: left;
    }
    .info-chip-icon {
        width: 32px; height: 32px; border-radius: 8px;
        display: flex; align-items: center; justify-content: center;
        font-size: 14px; flex-shrink: 0; margin-top: 1px;
    }
    .info-chip-title { font-size: 13px; font-weight: 600; color: var(--text); margin-bottom: 2px; }
    .info-chip-text  { font-size: 12px; color: var(--muted); line-height: 1.5; }

    /* ── Botones ── */
    .btn-group-reset {
        display: flex; flex-direction: column; gap: 10px;
        animation: fadeUp .4s .4s ease both;
    }

    .btn-primary-reset {
        display: flex; align-items: center; justify-content: center; gap: 9px;
        background: linear-gradient(135deg, var(--accent), #1d4ed8);
        border: none; border-radius: 12px;
        color: #fff; font-family: var(--font);
        font-size: 14px; font-weight: 600;
        padding: 14px 20px; cursor: pointer; text-decoration: none;
        transition: transform .15s, box-shadow .2s, filter .2s;
        box-shadow: 0 8px 24px rgba(37,99,235,.35);
        letter-spacing: .2px;
    }
    .btn-primary-reset:hover {
        transform: translateY(-1px); filter: brightness(1.07);
        box-shadow: 0 12px 32px rgba(37,99,235,.45);
        color: #fff;
    }
    .btn-primary-reset:active { transform: scale(.98); }

    .btn-secondary-reset {
        display: flex; align-items: center; justify-content: center; gap: 9px;
        background: none;
        border: 1.5px solid var(--border);
        border-radius: 12px;
        color: var(--muted); font-family: var(--font);
        font-size: 14px; font-weight: 500;
        padding: 13px 20px; cursor: pointer; text-decoration: none;
        transition: border-color .2s, color .2s, background .2s;
    }
    .btn-secondary-reset:hover {
        border-color: rgba(255,255,255,.2);
        color: var(--text);
        background: rgba(255,255,255,.04);
    }

    /* ── Divisor ── */
    .divider {
        display: flex; align-items: center; gap: 12px; margin: 4px 0;
    }
    .divider::before, .divider::after {
        content: ''; flex: 1; height: 1px; background: var(--border);
    }
    .divider span { font-size: 11px; color: #374151; }

    /* ── Footer ── */
    .page-footer {
        position: relative; z-index: 10;
        padding: 20px; text-align: center;
        font-size: 11px; color: #374151;
        border-top: 1px solid var(--border);
    }

    @@media (max-width: 520px) {
        .token-card  { padding: 36px 24px; }
        .token-title { font-size: 22px; }
        .top-bar     { padding: 20px; }
    }
    </style>
</head>
<body>

<div class="bg-dots"></div>

<!-- ── Topbar ── -->
<div class="top-bar">
    <img src="~/images/logos/logo_blue.png"
         onerror="this.style.display='none';document.getElementById('logoIcon').style.display='flex';"
         class="top-logo-img" alt="Logo" />
    <div class="top-logo-icon" id="logoIcon" style="display:none;">
        <i class="fa-solid fa-truck"></i>
    </div>
    <div>
        <div class="top-logo-name">TransporteApp</div>
        <div class="top-logo-sub">Sistema de Gestión</div>
    </div>
</div>

<!-- ── Contenido central ── -->
<div class="page-center">
    <div class="token-card">

        <!-- Icono animado -->
        <div class="token-icon-ring">
            <div class="token-icon-inner">
                <i class="fa-solid fa-link-slash"></i>
            </div>
        </div>

        <!-- Badge -->
        <div class="token-badge">
            <i class="fa-solid fa-triangle-exclamation" style="font-size:9px;"></i>
            Enlace no válido
        </div>

        <!-- Título -->
        <h1 class="token-title">Token inválido o vencido</h1>

        <!-- Descripción -->
        <p class="token-desc">
            El enlace para restablecer la contraseña
            <strong style="color:var(--text);">ya fue usado o ha expirado.</strong>
            Los enlaces de recuperación son de un solo uso y tienen una validez limitada.
        </p>

        <!-- Info chips -->
        <div class="info-chips">
            <div class="info-chip">
                <div class="info-chip-icon" style="background:rgba(239,68,68,.12);">
                    <i class="fa-solid fa-clock" style="color:#f87171;"></i>
                </div>
                <div>
                    <div class="info-chip-title">Enlace expirado</div>
                    <div class="info-chip-text">Los enlaces tienen un tiempo de validez limitado por seguridad.</div>
                </div>
            </div>
            <div class="info-chip">
                <div class="info-chip-icon" style="background:rgba(245,158,11,.1);">
                    <i class="fa-solid fa-rotate" style="color:#fbbf24;"></i>
                </div>
                <div>
                    <div class="info-chip-title">¿Qué puedes hacer?</div>
                    <div class="info-chip-text">Solicita un nuevo enlace desde la pantalla de inicio de sesión.</div>
                </div>
            </div>
        </div>

        <!-- Botones -->
        <div class="btn-group-reset">
            <a href="@Url.Action("Login","Account")"
               class="btn-primary-reset">
                <i class="fa-solid fa-arrow-left"></i>
                Regresar al inicio de sesión
            </a>

            <div class="divider"><span>o</span></div>

            <a href="@Url.Action("Login","Account", new{ abrirRestablecer = true })"
               class="btn-secondary-reset"
               onclick="sessionStorage.setItem('abrirRestablecerModal','1')">
                <i class="fa-solid fa-envelope"></i>
                Solicitar nuevo enlace de recuperación
            </a>
        </div>

    </div>
</div>

<!-- ── Footer ── -->
<div class="page-footer">
    © @DateTime.Now.Year TransporteApp — Todos los derechos reservados
</div>

<script src="~/lib/jquery/dist/jquery.min.js"></script>
<script src="~/lib/bootstrap/dist/js/bootstrap.js"></script>
<script src="~/lib/fontawesome/js/all.min.js"></script>
<script>
    // Si viene de token inválido, abrir el modal de restablecimiento automáticamente en el login
    document.querySelector('.btn-secondary-reset')?.addEventListener('click', function (e) {
        sessionStorage.setItem('abrirRestablecerModal', '1');
    });
</script>
</body>
</html>
