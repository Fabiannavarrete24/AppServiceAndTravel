@model AppServiceAndTravel.Models.ProveedorExterno
@using AppServiceAndTravel.Models
@{ var esEdit = Model.Id > 0; ViewData["Title"] = esEdit ? $"Editar: {Model.RazonSocial}" : "Nuevo Proveedor Externo"; }

<div class="row g-4">
  <div class="col-lg-8">
    <div class="card">
      <div class="card-header bg-white py-3 px-4 d-flex align-items-center gap-2">
        <div class="rounded-3 d-flex align-items-center justify-content-center"
             style="width:36px;height:36px;background:#ccfbf1;font-size:18px;color:#0f766e;">
          <i class="bi bi-building"></i></div>
        <div>
          <h5 class="mb-0 fw-semibold">@ViewData["Title"]</h5>
          <small class="text-muted">Empresa o persona que presta servicios de transporte externo</small>
        </div>
      </div>
      <div class="card-body px-4 py-4">
        <form asp-area="RH" asp-controller="ProveedorExterno"
              asp-action="@(esEdit?"Edit":"Create")" method="post">
          @Html.AntiForgeryToken()
          @if(esEdit){ <input type="hidden" asp-for="Id" /> }
          <div asp-validation-summary="ModelOnly" class="alert alert-danger rounded-3 py-2 small"></div>

          <h6 class="fw-semibold small text-uppercase text-muted mb-3">Información legal</h6>
          <div class="row g-3 mb-4">
            <div class="col-md-8">
              <label asp-for="RazonSocial" class="form-label fw-semibold small">Razón social / Nombre *</label>
              <input asp-for="RazonSocial" class="form-control rounded-3" required />
              <span asp-validation-for="RazonSocial" class="text-danger small"></span>
            </div>
            <div class="col-md-4">
              <label asp-for="NitCedula" class="form-label fw-semibold small">NIT / Cédula *</label>
              <input asp-for="NitCedula" class="form-control rounded-3" required />
              <span asp-validation-for="NitCedula" class="text-danger small"></span>
            </div>
            <div class="col-12">
              <label asp-for="Direccion" class="form-label fw-semibold small">Dirección</label>
              <input asp-for="Direccion" class="form-control rounded-3" />
            </div>
          </div>

          <h6 class="fw-semibold small text-uppercase text-muted mb-3">Contacto</h6>
          <div class="row g-3 mb-4">
            <div class="col-md-6">
              <label asp-for="Contacto" class="form-label fw-semibold small">Persona de contacto</label>
              <input asp-for="Contacto" class="form-control rounded-3" placeholder="Nombre del representante" />
            </div>
            <div class="col-md-3">
              <label asp-for="Telefono" class="form-label fw-semibold small">Teléfono *</label>
              <input asp-for="Telefono" class="form-control rounded-3" required />
              <span asp-validation-for="Telefono" class="text-danger small"></span>
            </div>
            <div class="col-md-3">
              <label class="form-label fw-semibold small">Email</label>
              <input type="email" class="form-control rounded-3" />
            </div>
          </div>

          <h6 class="fw-semibold small text-uppercase text-muted mb-3">Tipo de servicio y tarifa</h6>
          <div class="row g-3 mb-4">
            <div class="col-md-6">
              <label asp-for="TipoServicio" class="form-label fw-semibold small">¿Qué provee? *</label>
              <select asp-for="TipoServicio" class="form-select rounded-3"
                      asp-items="Html.GetEnumSelectList<AppServiceAndTravel.Models.TipoServicioExterno>()"></select>
            </div>
            <div class="col-md-6">
              <label asp-for="TarifaBase" class="form-label fw-semibold small">Tarifa base por servicio</label>
              <div class="input-group">
                <span class="input-group-text">$</span>
                <input asp-for="TarifaBase" type="number" class="form-control rounded-end-3" step="1000" min="0" />
              </div>
            </div>
          </div>

          <div class="mb-4">
            <label asp-for="Observaciones" class="form-label fw-semibold small">Observaciones / Condiciones</label>
            <textarea asp-for="Observaciones" class="form-control rounded-3" rows="3"
                      placeholder="Condiciones del contrato, restricciones, notas adicionales…"></textarea>
          </div>

          @if(esEdit)
          {
          <div class="mb-4">
            <div class="form-check form-switch">
              <input asp-for="Activo" class="form-check-input" type="checkbox" />
              <label asp-for="Activo" class="form-check-label fw-semibold small">Proveedor activo</label>
            </div>
          </div>
          }

          <div class="d-flex gap-3">
            <button type="submit" class="btn btn-primary px-4 rounded-3">
              <i class="bi @(esEdit?"bi-save":"bi-building") me-2"></i>
              @(esEdit ? "Guardar cambios" : "Registrar proveedor")
            </button>
            <a asp-area="RH" asp-controller="ProveedorExterno" asp-action="Index"
               class="btn btn-outline-secondary rounded-3">Cancelar</a>
          </div>
        </form>
      </div>
    </div>
  </div>

  <div class="col-lg-4">
    <div class="card">
      <div class="card-body p-4">
        <h6 class="fw-semibold mb-3"><i class="bi bi-info-circle me-2 text-primary"></i>Tipos de servicio</h6>
        @foreach(var (t,d) in new[]{
          ("Vehículo","Provee solamente el vehículo, sin conductor."),
          ("Conductor","Provee solamente el conductor, sin vehículo."),
          ("Ambos","Provee vehículo y conductor juntos."),
        })
        {
        <div class="d-flex gap-2 mb-3">
          <i class="bi bi-check-circle-fill text-success mt-1" style="flex-shrink:0;"></i>
          <div>
            <div class="fw-semibold small">@t</div>
            <div class="text-muted" style="font-size:12px;">@d</div>
          </div>
        </div>
        }
        <div class="alert alert-info rounded-3 small py-2 mb-0">
          <i class="bi bi-link-45deg me-1"></i>
          Al crear un servicio podrá seleccionar este proveedor como recurso externo.
        </div>
      </div>
    </div>
  </div>
</div>
@section Scripts { <partial name="_ValidationScriptsPartial" /> }
