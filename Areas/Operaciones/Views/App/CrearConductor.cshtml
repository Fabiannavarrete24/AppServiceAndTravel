
@{
    ViewData["Title"] = "Nuevo Conductor";
    ViewData["Breadcrumb"] = "Conductores / Nuevo";
}
<style>
    #tabsConductor .nav-link{
    border:none;
    color:#64748b;
    font-weight:500;
    padding:.65rem 1rem;
}

#tabsConductor .nav-link.active{
    background:#0d6efd;
    color:white;
}

#tabsConductor .nav-link:hover{
    background:#eff6ff;
}

.form-label.small{
    font-size:.78rem;
    letter-spacing:.3px;
    margin-bottom:.35rem;
}

.card{
    border-radius:1rem;
}

.input-group-text{
    background:#f8fafc;
}
</style>
<div class="card border-0 shadow-sm rounded-4">
    <div class="card-header bg-white border-0 py-3">
        <ul class="nav nav-pills gap-2" id="tabsConductor" role="tablist">
            <li class="nav-item">
                <button class="nav-link active rounded-3"
                        data-bs-toggle="tab"
                        data-bs-target="#tabGeneral"
                        type="button">
                    <i class="bi bi-person me-2"></i>
                    Información General
                </button>
            </li>

            <li class="nav-item">
                <button class="nav-link rounded-3"
                        data-bs-toggle="tab"
                        data-bs-target="#tabLicencia"
                        type="button">
                    <i class="bi bi-card-heading me-2"></i>
                    Licencia de Conducción
                </button>
            </li>
        </ul>
    </div>

    <div class="card-body">

        <input type="hidden" id="idConductor" />

        <div class="tab-content">

            <!-- GENERAL -->
            <div class="tab-pane fade show active" id="tabGeneral">

                <h6 class="fw-semibold small text-uppercase text-muted mb-3">
                    Datos Personales
                </h6>

                <div class="row g-3">

                    <div class="col-md-6">
                        <label class="form-label fw-semibold small">
                            Nombre Completo
                        </label>

                        <div class="input-group">
                            <span class="input-group-text bg-light">
                                <i class="bi bi-person"></i>
                            </span>
                            <input id="NombreCompleto"
                                   class="form-control" />
                        </div>
                    </div>

                    <div class="col-md-3">
                        <label class="form-label fw-semibold small">
                            Documento
                        </label>

                        <div class="input-group">
                            <span class="input-group-text bg-light">
                                <i class="bi bi-card-text"></i>
                            </span>
                            <input id="Cedula"
                                   class="form-control" />
                        </div>
                    </div>

                    <div class="col-md-3">
                        <label class="form-label fw-semibold small">
                            Teléfono
                        </label>

                        <div class="input-group">
                            <span class="input-group-text bg-light">
                                <i class="bi bi-telephone"></i>
                            </span>
                            <input id="Telefono"
                                   class="form-control" />
                        </div>
                    </div>

                    <div class="col-md-6">
                        <label class="form-label fw-semibold small">
                            Correo Electrónico
                        </label>

                        <div class="input-group">
                            <span class="input-group-text bg-light">
                                <i class="bi bi-envelope"></i>
                            </span>
                            <input id="Correo"
                                   type="email"
                                   class="form-control" />
                        </div>
                    </div>

                    <div class="col-md-3">
                        <label class="form-label fw-semibold small">
                            Estado Persona
                        </label>
<select id="EstadoPersona" class="form-select"></select>
                    </div>

                    <div class="col-md-3">
                        <label class="form-label fw-semibold small">
                            Estado Conductor
                        </label>
<select id="EstadoConductor" class="form-select"></select>
                    </div>

                </div>

            </div>

            <!-- LICENCIA -->
            <div class="tab-pane fade" id="tabLicencia">

                <h6 class="fw-semibold small text-uppercase text-muted mb-3">
                    Información de la Licencia
                </h6>

                <div class="row g-3">

                    <div class="col-md-4">
                        <label class="form-label fw-semibold small">
                            Número Licencia
                        </label>

                        <input id="NumeroLicencia"
                               class="form-control" />
                    </div>

                    <div class="col-md-2">
                        <label class="form-label fw-semibold small">
                            Categoría
                        </label>

                        <input id="CategoriaLicencia"
                               class="form-control" />
                    </div>

                    <div class="col-md-2">
                        <label class="form-label fw-semibold small">
                            Categoría Anterior
                        </label>

                        <input id="CategoriaAnterior"
                               class="form-control" />
                    </div>

                    <div class="col-md-4">
                        <label class="form-label fw-semibold small">
                            Estado Licencia
                        </label>
<select id="EstadoLicencia"
        class="form-select"></select>
                    </div>

                    <div class="col-md-4">
                        <label class="form-label fw-semibold small">
                            Organismo Expide
                        </label>

                        <input id="OrganismoExpideLicencia"
                               class="form-control" />
                    </div>

                    <div class="col-md-4">
                        <label class="form-label fw-semibold small">
                            Fecha Expedición
                        </label>

                        <input id="FechaExpedicionLicencia"
                               type="date"
                               class="form-control" />
                    </div>

                    <div class="col-md-4">
                        <label class="form-label fw-semibold small">
                            Fecha Vencimiento
                        </label>

                        <input id="FechaVencimientoLicencia"
                               type="date"
                               class="form-control" />
                    </div>
<div class="col-md-3">
    <label class="form-label">
        Tiene Retención
    </label>

    <div class="form-check form-switch">
        <input id="TieneRetencionLicencia"
               class="form-check-input"
               type="checkbox">
    </div>
</div>
                    <div class="col-md-6">
                        <label class="form-label fw-semibold small">
                            Restricciones
                        </label>

                        <textarea id="RestriccionesLicencia"
                                  class="form-control"
                                  rows="3"></textarea>
                    </div>

                    <div class="col-md-6">
                        <label class="form-label fw-semibold small">
                            Retención
                        </label>

                        <textarea id="RetencionLicencia"
                                  class="form-control"
                                  rows="3"></textarea>
                    </div>
<div class="col-md-3">
    <label class="form-label">
        Tipo Proveedor
    </label>

    <select id="TipoProveedor"
            class="form-select">
    </select>
</div>
                    <div class="col-md-12">
                        <label class="form-label fw-semibold small">
                            Organismo que Cancela o Suspende
                        </label>

                        <input id="OrganismoCancelaLicencia"
                               class="form-control" />
                    </div>

                </div>

            </div>

        </div>

    </div>

    <div class="card-footer bg-white border-0 text-end">
<button type="button"
        id="btnCancelar"
        class="btn btn-outline-secondary rounded-3">
    Cancelar
</button>

<button type="button"
        id="btnGuardar"
        class="btn btn-primary rounded-3">
    <i class="bi bi-save me-2"></i>
    Guardar Conductor
</button>
    </div>
</div>

@section Scripts {
    <script>
function obtenerModel() {
    return {
        idConductor:parseInt($("#idConductor").val()) || 0,
        NombreCompleto:$("#NombreCompleto").val(),
        Cedula:$("#Cedula").val(),
        Telefono:$("#Telefono").val(),
        Correo:$("#Correo").val(),
        NumeroLicencia:$("#NumeroLicencia").val(),
        CategoriaLicencia:$("#CategoriaLicencia").val(),
        CategoriaLicenciaAnterior:$("#CategoriaAnterior").val(),
        FechaExpedicionLicencia:$("#FechaExpedicionLicencia").val() || null,
        FechaVencimientoLicencia:$("#FechaVencimientoLicencia").val() || null,
        OrganismoTransitoExpideLicencia:$("#OrganismoExpideLicencia").val(),
        RestriccionesLicencia:$("#RestriccionesLicencia").val(),
        TieneRetencionLicencia:$("#TieneRetencionLicencia").is(":checked"),
        RetencionLicencia:$("#RetencionLicencia").val(),
        OrganismoTransitoCancelaLicencia:$("#OrganismoCancelaLicencia").val(),
        EstadoLicencia:parseInt($("#EstadoLicencia").val()) || 0,
        TipoProveedor:parseInt($("#TipoProveedor").val()) || 0,
        EstadoPersona:parseInt($("#EstadoPersona").val()) || 0,
        EstadoConductor:parseInt($("#EstadoConductor").val()) || 0
    }
}

$("#btnGuardar").click(function () {

    const model = obtenerModel();

    $.ajax({
        url: '/Operaciones/Conductores/GuardarConductor',
        type: 'POST',
        data: model,

        beforeSend: function () {
            showLoader();
        },

        success: function (response) {

            if (response.success) {

                toastr.success(response.message);

                if (response.data != null) {
                    $("#idConductor").val(response.data.idConductor);
                }

            } else {
                toastr.error(response.message);
            }
        },

        error: function (xhr) {
            toastr.error("Error guardando conductor");
            console.error(xhr);
        },

        complete: function () {
            hideLoader();
        }
    });

});
function cargarConductor(id) {

    $.ajax({
        url: '/Operaciones/Conductores/ObtenerConductor',
        type: 'GET',
        data: { id: id },

        beforeSend: function () {
            showLoader();
        },

        success: function (response) {

            if (!response.success)
                return toastr.error(response.message);

            llenarFormulario(response.data);
        },

        complete: function () {
            hideLoader();
        }
    });

}
function llenarFormulario(model) {

    $("#idConductor").val(model.idConductor);

    $("#NombreCompleto").val(model.nombreCompleto);
    $("#Cedula").val(model.cedula);
    $("#Telefono").val(model.telefono);
    $("#Correo").val(model.correo);

    $("#EstadoPersona").val(model.estadoPersona);
    $("#EstadoConductor").val(model.estadoConductor);

    $("#NumeroLicencia").val(model.numeroLicencia);
    $("#CategoriaLicencia").val(model.categoriaLicencia);
    $("#CategoriaAnterior").val(model.categoriaLicenciaAnterior);

    $("#EstadoLicencia").val(model.estadoLicencia);

    $("#OrganismoExpideLicencia")
        .val(model.organismoTransitoExpideLicencia);

    $("#FechaExpedicionLicencia")
        .val(model.fechaExpedicionLicencia?.split('T')[0]);

    $("#FechaVencimientoLicencia")
        .val(model.fechaVencimientoLicencia?.split('T')[0]);

    $("#RestriccionesLicencia")
        .val(model.restriccionesLicencia);

    $("#RetencionLicencia")
        .val(model.retencionLicencia);

    $("#OrganismoCancelaLicencia")
        .val(model.organismoTransitoCancelaLicencia);
}
function eliminarConductor(id) {

    Swal.fire({
        title: '¿Eliminar conductor?',
        text: 'Esta acción no se puede deshacer',
        icon: 'warning',
        showCancelButton: true,
        confirmButtonText: 'Eliminar'
    }).then((result) => {

        if (!result.isConfirmed)
            return;

        $.ajax({
            url: '/Operaciones/Conductores/EliminarConductor',
            type: 'DELETE',
            data: { id: id },

            beforeSend: function () {
                showLoader();
            },

            success: function (response) {

                if (response.success) {

                    toastr.success(response.message);

                    setTimeout(() => {
                        window.location.href =
                            '/Operaciones/Conductores';
                    }, 1000);

                } else {
                    toastr.error(response.message);
                }
            },

            complete: function () {
                hideLoader();
            }
        });

    });
}
function limpiarFormulario() {

    $("#idConductor").val(0);

    $("#NombreCompleto").val('');
    $("#Cedula").val('');
    $("#Telefono").val('');
    $("#Correo").val('');

    $("#EstadoPersona").val('');
    $("#EstadoConductor").val('');

    $("#NumeroLicencia").val('');
    $("#CategoriaLicencia").val('');
    $("#CategoriaAnterior").val('');

    $("#EstadoLicencia").val('');

    $("#OrganismoExpideLicencia").val('');
    $("#FechaExpedicionLicencia").val('');
    $("#FechaVencimientoLicencia").val('');

    $("#RestriccionesLicencia").val('');
    $("#RetencionLicencia").val('');
    $("#OrganismoCancelaLicencia").val('');
}
$("#btnCancelar").click(function () {

    Swal.fire({
        title: '¿Cancelar cambios?',
        icon: 'question',
        showCancelButton: true,
        confirmButtonText: 'Sí'
    }).then((r) => {

        if (r.isConfirmed) {
            limpiarFormulario();
        }

    });

});
    </script>
}