
@{
    ViewData["Title"] = "Nuevo Conductor";
    ViewData["Breadcrumb"] = "Conductores / Nuevo";
}
@section Styles{
<style>

    @@media (max-width: 1200px) {
        .flex-row {
            flex-direction: column !important;
        }
    }

    @@media (max-width: 990px) {
        #content {
            flex-direction: column-reverse !important;
        }
    }    
    
</style>
}
<div class="row" id="content">
    <div class="col-lg-8 mt-3">
        <div class="card border-0 shadow-sm rounded-4 mb-3">
            <div class="card-body d-flex justify-content-between align-items-center">
            <div class="d-flex gap-1">
                <button type="button" class="btn btn-primary" id="btnNuevo">
                <i class="fa-regular fa-square-plus"></i>
                </button>
                <button type="button" class="btn btn-success" id="btnGuardar">
                <i class="fa-solid fa-save"></i>
                </button>
                <button type="button" class="btn btn-warning" id="btnEditar">
                <i class="fa-regular fa-pen-to-square"></i>
                </button>
                <button type="button" class="btn btn-danger" id="btnDeshabilitar">
                <i class="fa-solid fa-ban"></i>
                </button>
            </div>
            <div style="width: 30%;">
                <input id="txtBuscar" class="form-control" placeholder="Buscar ..." />
            </div>
            </div>
        </div>
        <form class="card border-0 shadow-sm rounded-4 mb-3" id="frmConductor">
            <div class="card-header bg-white border-0">
                <ul class="nav nav-pills mb-3" id="pills-tab" role="tablist">
                <li class="nav-item" role="presentation">
                    <button class="nav-link active" id="general-tab" data-bs-toggle="pill" data-bs-target="#general"
                            type="button" role="tab" aria-controls="general" aria-selected="true">
                    General
                    </button>
                </li>
                <li class="nav-item" role="presentation">
                    <button class="nav-link" id="licencia-tab" data-bs-toggle="pill" data-bs-target="#licencia"
                            type="button" role="tab" aria-controls="licencia" aria-selected="false">
                    Licencia
                    </button>
                </li>          
                </ul>                
            </div>
            <div class="card-body">
                <input type="hidden" id="idConductor" value="@ViewBag.IdConductor" />
                <div class="tab-content">        
                <div class="tab-pane fade show active" id="general" role="tabpanel" aria-labelledby="general-tab" tabindex="0">
                        <h6 class="fw-semibold small text-uppercase text-muted mb-3">Datos Personales</h6>
                        <div class="row gy-3">
                            <div class="col-md-2">
                                <label class="form-label fw-semibold small">Tipo Documento</label>
                                <select id="TipoDocumento" class="form-select" required></select>
                            </div>          
                            <div class="col-md-3">
                                <label class="form-label fw-semibold small">Documento</label>
                                <input id="Cedula" class="form-control" required/>
                            </div>                            
                            <div class="col-md-4">
                                <label class="form-label fw-semibold small">Nombre Completo</label>
                                <input id="NombreCompleto" class="form-control" required/>
                            </div>
                            <div class="col-md-3">
                                <label class="form-label fw-semibold small">Teléfono</label>
                                <input id="Telefono" class="form-control" required/>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label fw-semibold small">Correo Electrónico</label>
                                <input id="Correo" type="email" class="form-control" />
                            </div>
                            <div class="col-md-2">
                                <label class="form-label fw-semibold small">Activo</label>
                                <div class="form-check form-switch">
                                    <input class="form-check-input" type="checkbox" role="switch" id="EstadoConductor">
                                </div>
                            </div>
                            <div class="col-md-4">
                                <label class="form-label">Conductor</label>
                                <div class="d-flex flex-row">
                                    <div class="form-check"
                                            style="display: flex; align-content: center; align-items: center; justify-content: center; gap: 28px;">
                                        <input class="form-check-input" type="radio" name="radioDefault" id="Interno" checked>
                                        <label class="form-check-label" for="Interno" style="margin-bottom:-5px;">Interno</label>
                                    </div>
                                    <div class="form-check"
                                            style="display: flex; align-content: center; align-items: center; justify-content: center; gap: 28px;">
                                        <input class="form-check-input" type="radio" name="radioDefault" id="Externo">
                                        <label class="form-check-label" for="Externo" style="margin-bottom:-5px;">Externo</label>
                                    </div>
                                </div>
                            </div>                               
                        </div>
                </div>
                <div class="tab-pane fade" id="licencia" role="tabpanel" aria-labelledby="licenica-tab" tabindex="0">
                        <h6 class="fw-semibold small text-uppercase text-muted mb-3">
                            Información de la Licencia<span id="EstadoLicenciaBadge" class="badge rounded-pill text-bg-secondary ms-2 align-self-center d-none">Sin calcular</span>
                        </h6>
                        <div class="row g-3">
                            <div class="col-md-4">
                                <label class="form-label fw-semibold small">Número Licencia</label>
                                <input id="NumeroLicencia" class="form-control" required/>
                            </div>
                            <div class="col-md-2">
                                <label class="form-label fw-semibold small">Categoría</label>
                                <select id="CategoriaLicencia" class="form-select" required></select>
                            </div>
                            <div class="col-md-1">
                                <label class="form-label fw-semibold small">Activa</label>
                                <div class="form-check form-switch">
                                    <input class="form-check-input" type="checkbox" role="switch" id="EstadoLicencia" disabled required>                                    
                                </div>
                            </div>                         
                            <div class="col-md-5">
                                <label class="form-label fw-semibold small">Organismo Expide</label>
                                <input id="OrganismoExpideLicencia" class="form-control" />
                            </div>
                            <div class="col-md-2">
                                <label class="form-label fw-semibold small">Fecha Expedición</label>
                                <input id="FechaExpedicionLicencia" type="date" class="form-control" required/>
                            </div>
                            <div class="col-md-2">
                                <label class="form-label fw-semibold small">Fecha Vencimiento</label>
                                <input id="FechaVencimientoLicencia" type="date" class="form-control" required/>
                            </div>
                            <div class="col-md-2">
                                <label class="form-label fw-semibold small">Vigencia</label>
                                <input type="number" id="VigenciaLicencia" class="form-control" disabled required/>
                            </div>                            
                            <div class="col-md-6">
                                <label class="form-label fw-semibold small">Restricciones</label>
                                <textarea id="RestriccionesLicencia" class="form-control" rows="3"></textarea>
                            </div>
                        </div>
                </div>                    
                </div>
            </div>
        </form>
    </div>
    <div class="col-lg-4 mt-3">
        <div class="card border-0 shadow-sm rounded-4">
        <div class="card-body p-4">
            <h6 class="fw-semibold mb-3"><i class="bi bi-info-circle me-2 text-primary"></i>Documentos requeridos</h6>
            @foreach (var (icon, doc, desc) in new[] {
            ("bi-file-earmark-check", "SOAT", "Seguro Obligatorio de Accidentes de Tránsito"),
            ("bi-wrench-adjustable", "Revisión Técnico-Mecánica", "Certificado de revisión periódica obligatoria"),
            ("bi-shield-shaded", "Seguro del Vehículo", "Póliza de seguro todo riesgo o responsabilidad civil")
            })
            {
            <div class="d-flex gap-3 mb-3">
                <div class="rounded-3 d-flex align-items-center justify-content-center flex-shrink-0"
                    style="width:34px;height:34px;background:#dbeafe;font-size:16px;color:#1d4ed8;">
                <i class="bi @icon"></i>
                </div>
                <div>
                <div class="fw-semibold small">@doc</div>
                <div class="text-muted" style="font-size:12px;">@desc</div>
                </div>
            </div>
            }
            <div class="alert alert-warning rounded-3 small py-2 mt-2 mb-0">
            <i class="bi bi-exclamation-triangle me-1"></i>
            El sistema alertará 30 días antes del vencimiento de cada documento.
            </div>
        </div>
        </div>
    </div>
</div>
<div class="modal fade" id="modalConductores" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">
                    Conductores encontrados
                </h5>
                <button class="btn-close" data-bs-dismiss="modal">
                </button>
            </div>
            <div class="modal-body">
                <table class="table table-hover">
                    <thead>
                        <tr>
                            <th>Documento</th>
                            <th>Nombre</th>
                            <th>Teléfono</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody id="tblConductores">
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
@section Scripts {
<script>
$(document).ready(function () {

    cargarListados();

    let idConductor = $("#idConductor").val();

    if (idConductor && parseInt(idConductor) > 0) {
        cargarConductor(idConductor);
    }
    else {
        limpiarFormulario();
    }

    calcularDiasVigencia('#FechaExpedicionLicencia','#FechaVencimientoLicencia','#VigenciaLicencia');
});    
    
    $('#FechaExpedicionLicencia, #FechaVencimientoLicencia').on('change', function () {
        calcularDiasVigencia('#FechaExpedicionLicencia','#FechaVencimientoLicencia','#VigenciaLicencia');
        actualizarBadgeVigencia('#VigenciaLicencia','#EstadoLicenciaBadge');
    });

@* $("#Cedula").on("blur", function () {

