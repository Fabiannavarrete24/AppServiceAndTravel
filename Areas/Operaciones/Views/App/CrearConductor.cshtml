    $.ajax({
        url: '/Empleados/Empleados/ObtenerEmpleadoPorDocumento',
        type: 'GET',
        data: {
            documento: documento
        },
        success: function (response) {
                console.log(response);
            if (!response.success)
                return;

            let empleado = response.data;

            $("#NombreCompleto").val(empleado.nombreCompleto);
            $("#Telefono").val(empleado.telefono);
            $("#Correo").val(empleado.correo);
            $("#TipoDocumento").val(empleado.tipoDocumento);

            $("#Interno").prop("checked", true);

            toastr.info("Los datos fueron cargados desde Empleados.");
        }
    });

}); *@

let timeoutBusqueda = null;

    $("#txtBuscar").on("keyup", function () {

        const valor = $(this).val().trim();

        clearTimeout(timeoutBusqueda);

        if (valor.length === 0) {
            busquedaActual = "";
            buscarConductores();
            return;
        }    

        timeoutBusqueda = setTimeout(() => {

            if (valor.length < 5) {
                toastr.warning("debe ingresar mas caracteres");
                return;
            }

            busquedaActual = valor;
            buscarConductores();
        }, 1000);
    });

    function buscarConductores() {

        let filtro = $("#txtBuscar").val();

        if (!filtro)
            return;
        
        $.ajax({
            url: '/Operaciones/Conductores/BuscarConductores',
            type: 'GET',
            data: {
                filtro: filtro
            },
            beforeSend: showLoader,
            complete: hideLoader,
            success: function (response) {

                if (!response.success)
                    return toastr.error(response.message);

                let lista = response.data;

                if (lista.length === 0) {
                    toastr.warning("No se encontraron coincidencias.");
                    return;
                }

                if (lista.length === 1) {
                    cargarConductor(lista[0].idConductor);
                    return;
                }

                llenarModalConductores(lista);

                $("#modalConductores").modal("show");
            }
        });

    }
    
    function llenarModalConductores(lista) {
            console.log("imprimiendo lista",lista);
        let html = "";

        lista.forEach(x => {

            html += `
            <tr>
                <td>${x.cedula}</td>
                <td>${x.nombreCompleto}</td>
                <td>${x.telefono ?? ''}</td>
                <td>

                    <button
                        class="btn btn-primary btn-sm btnSeleccionarConductor"
                        data-id="${x.idConductor}">

                        Seleccionar

                    </button>

                </td>
            </tr>
            `;
        });

        $("#tblConductores").html(html);
    } 
    
    $(document).on("click",".btnSeleccionarConductor",
        function () {

            let id = $(this).data("id");

            $("#modalConductores").modal("hide");

            cargarConductor(id);
        }
    );

    function cargarListados() {
      try {
        $.ajax({
            url: '/Helps/ObtenerListadoSelect',
            type: 'GET',
            beforeSend: function () {
                showLoader();
            },
            success: function(response){
                LoadSelect("#TipoDocumento", response.data.tiposDocumento);
                LoadSelect("#CategoriaLicencia", response.data.tiposLicencia);
            },
            complete: function () {
                hideLoader();
            }
        });  
      }
      catch (e) {
        console.error(e);
      }
    }

    function obtenerModel() {
        return {
            //datos generales
            idConductor:parseInt($("#idConductor").val()) || 0,
            NombreCompleto:$("#NombreCompleto").val(),
            TipoDocumento:$("#TipoDocumento").val(),
            Cedula:$("#Cedula").val(),
            Telefono:$("#Telefono").val(),
            Correo:$("#Correo").val(),
            EstadoConductor:$("#EstadoConductor").is(":checked") ? 1 : 0,        
            TipoConductor:$("#Interno").is(":checked") ? 0 : 1,
            //licencia
            NumeroLicencia:$("#NumeroLicencia").val(),
            CategoriaLicencia:$("#CategoriaLicencia").val(),
            EstadoLicencia:$("#EstadoLicencia").is(":checked") ? 1 : 0,            
            OrganismoExpide:$("#OrganismoExpideLicencia").val(),

            FechaExpedicionLicencia:$("#FechaExpedicionLicencia").val() || null,
            FechaVencimientoLicencia:$("#FechaVencimientoLicencia").val() || null,
            Vigencia:$("#VigenciaLicencia").val(),
            
            RestriccionesLicencia:$("#RestriccionesLicencia").val(),
        }
    }

    $("#btnGuardar").click(function () {

        const model = obtenerModel();

        if (!validateForm("#frmConductor"))
        return;

        $.ajax({
            url: '/Operaciones/Conductores/GuardarConductor',
            type: 'POST',
            data: model,
            beforeSend: function () {
                showLoader();
            },
            success: function (response) {
                if (response.success) {
                    toastr.success(response.message);
                    if (response.data != null) {
                        $("#idConductor").val(response.data.idConductor);
                    }
                } else {
                    toastr.error(response.message);
                }
            },
            error: function (xhr) {
                toastr.error("Error guardando conductor");
                console.error(xhr);
            },
            complete: function () {
                hideLoader();
            }
        });

    });

    function cargarConductor(id) {
        $.ajax({
            url: '/Operaciones/Conductores/ObtenerConductor',
            type: 'GET',
            data: { id: id },
            beforeSend: function () {
                showLoader();
            },
            success: function (response) {
                if (!response.success)
                    return toastr.error(response.message);

                llenarFormulario(response.data);
            },
            complete: function () {
                hideLoader();
            }
        });
    }

    function llenarFormulario(model) {

        $("#idConductor").val(model.idConductor);
        $("#NombreCompleto").val(model.nombreCompleto);
        $("#TipoDocumento").val(model.tipoDocumento);
        $("#Cedula").val(model.cedula);
        $("#Telefono").val(model.telefono);
        $("#Correo").val(model.correo);

        $("#EstadoConductor").prop("checked",model.activo);
        if (model.tipoConductor = "Interno" )
        $("#Interno").prop("checked", true);
        else
        $("#Externo").prop("checked", true);
        
        $("#NumeroLicencia").val(model.numeroLicencia);
        $("#CategoriaLicencia").val(model.categoriaLicencia);
        $("#EstadoLicencia").prop("checked",model.estadoLicencia);

        $("#OrganismoExpideLicencia").val(model.organismoExpide);
        $("#FechaExpedicionLicencia").val(model.fechaExpedicionLicencia?.substring(0,10));
        $("#FechaVencimientoLicencia").val(model.fechaVencimientoLicencia?.substring(0,10));
        $("#VigenciaLicencia").val(model.vigencia);
        $("#RestriccionesLicencia").val(model.restriccionesLicencia);

        actualizarBadgeVigencia('#VigenciaLicencia','#EstadoLicenciaBadge');
    }

    function eliminarConductor(id) {

        Swal.fire({
            title: '¿Eliminar conductor?',
            text: 'Esta acción no se puede deshacer',
            icon: 'warning',
            showCancelButton: true,
            confirmButtonText: 'Eliminar'
        }).then((result) => {

            if (!result.isConfirmed)
                return;

            $.ajax({
                url: '/Operaciones/Conductores/EliminarConductor',
                type: 'DELETE',
                data: { id: id },
                beforeSend: function () {
                    showLoader();
                },
                success: function (response) {

                    if (response.success) {
                        toastr.success(response.message);
                        setTimeout(() => {
                            window.location.href =
                                '/Operaciones/Conductores';
                        }, 1000);
                    } else {
                        toastr.error(response.message);
                    }
                },
                complete: function () {
                    hideLoader();
                }
            });

        });
    }

    function limpiarFormulario() {

        $("#idConductor").val(0);
        $("#NombreCompleto").val("");
        $("#TipoDocumento").val("");
        $("#Cedula").val("");
        $("#Telefono").val("");
        $("#Correo").val("");
        $("#EstadoConductor").prop("checked",false);
        $("#Interno").prop("checked",false);
            //licencia
        $("#NumeroLicencia").val("");
        $("#CategoriaLicencia").val("");
        $("#EstadoLicencia").prop("checked",false);
        $("#OrganismoExpideLicencia").val(""),

        $("#FechaExpedicionLicencia").val("");
        $("#FechaVencimientoLicencia").val("");
        $("#VigenciaLicencia").val("");
            
        $("#RestriccionesLicencia").val("");
    }

    $("#btnCancelar").click(function () {

        Swal.fire({
            title: '¿Cancelar cambios?',
            icon: 'question',
            showCancelButton: true,
            confirmButtonText: 'Sí'
        }).then((r) => {

            if (r.isConfirmed) {
                limpiarFormulario();
            }

        });

    });
</script>
}