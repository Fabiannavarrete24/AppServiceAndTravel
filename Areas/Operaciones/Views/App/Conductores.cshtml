@{
    ViewData["Title"] = "Conductores";
    ViewData["Breadcrumb"] = "Gestión de conductores";
}

<div class="row g-3 mb-4">
    <div class="col-md-3">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body d-flex gap-3 align-items-center">
                <div class="rounded-circle d-flex align-items-center justify-content-center"
                     style="width:48px;height:48px;background:#dbeafe;color:#1d4ed8;">
                    <i class="bi bi-people-fill"></i>
                </div>
                <div>
                    <small class="text-muted">Total</small>
                    <div class="fw-bold fs-4" id="totalConductores">0</div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body d-flex gap-3 align-items-center">
                <div class="rounded-circle d-flex align-items-center justify-content-center"
                     style="width:48px;height:48px;background:#d1fae5;color:#065f46;">
                    <i class="bi bi-person-check-fill"></i>
                </div>
                <div>
                    <small class="text-muted">Internos</small>
                    <div class="fw-bold fs-4" id="totalInternos">0</div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body d-flex gap-3 align-items-center">
                <div class="rounded-circle d-flex align-items-center justify-content-center"
                     style="width:48px;height:48px;background:#fef3c7;color:#92400e;">
                    <i class="bi bi-person-badge-fill"></i>
                </div>
                <div>
                    <small class="text-muted">Externos</small>
                    <div class="fw-bold fs-4" id="totalExternos">0</div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body d-flex gap-3 align-items-center">
                <div class="rounded-circle d-flex align-items-center justify-content-center"
                     style="width:48px;height:48px;background:#fee2e2;color:#991b1b;">
                    <i class="bi bi-exclamation-triangle-fill"></i>
                </div>
                <div>
                    <small class="text-muted">Licencias vencidas</small>
                    <div class="fw-bold fs-4" id="licenciasVencidas">0</div>
                </div>
            </div>
        </div>
    </div>
</div>
<div class="card border-0 shadow-sm">
    <div class="card-header bg-white d-flex flex-wrap gap-3 align-items-center py-3 justify-content-between">
        <span class="fw-semibold flex-grow-1">
            Conductores registrados
        </span>
        <div class="btn-group btn-group-sm">
            <button class="btn btn-dark" id="btnTodos">
                Todos
            </button>
            <button class="btn btn-outline-primary" id="btnInternos">
                Internos
            </button>
            <button class="btn btn-outline-secondary" id="btnExternos">
                Externos
            </button>
        </div>
        <input id="filterBusqueda" type="search" class="form-control form-control-sm" placeholder="Buscar conductor..." style="max-width:220px;">
        <a asp-area="Operaciones" asp-controller="App" asp-action="CrearConductor" class="btn btn-primary btn-sm">
            <i class="bi bi-plus-lg me-1"></i>Nuevo
        </a>
    </div>
    <div class="card-body p-0">

        <div class="table-responsive">
            <table class="table table-hover mb-0" id="tbodyConductores">
                <thead>
                    <tr>
                        <th class="ps-4">Conductor</th>
                        <th>Cédula</th>
                        <th>Teléfono</th>
                        <th>Licencia</th>
                        <th>Tipo</th>
                        <th>Estado</th>
                        <th class="text-end pe-4">Acciones</th>
                    </tr>
                </thead>
                <tbody>
                </tbody>
            </table>
        </div>
    </div>
    <div class="card-footer bg-white d-flex justify-content-between align-items-center">
        <div id="infoConductores"></div>
        <div class="btn-group" id="paginacionConductores">
        </div>
    </div>
</div>
@section Scripts {
<script>
    $(document).ready(function () {
        renderStats();
    });

    let paginaActual = 1;
    let tipoActual = null;
    let busquedaActual = "";
        
    $("#btnTodos").click(function () {
        tipoActual = null;
        conductoresTable.load(1);
    });
    
    $("#btnInternos").click(function () {
        tipoActual = 0;
        conductoresTable.load(1);
    });

    $("#btnExternos").click(function () {
        tipoActual = 1;
        conductoresTable.load(1);
    });

    const conductoresTable = new TableManager({
        url: '/Operaciones/Conductores/ObtenerConductores',
        tableId: '#tableConductores',
        paginationId: '#paginacionConductores',
        infoId: '#infoConductores',
        pageSize: 10,
        filters: {
            busqueda: '#txtBusqueda',
            tipo: '#filterTipoConductor'
        },
        beforeSend: () => showLoader(),
        onComplete: () => hideLoader(),
        renderTable: (data) => {

            const tbody = $("#tbodyConductores tbody");
            tbody.empty();

            if (!data || data.length === 0) {
                tbody.append(`
                    <tr>
                        <div class="text-center py-5 text-muted" id="table">
                            <i class="bi bi-inbox" style="font-size:40px;opacity:.3;"></i>
                            <p class="mt-2 mb-0">No hay conductores registrados.</p>
                        </div>
                    </tr>
                `);
                return;
            }

            data.forEach(c => {

                const estado = c.activo ? `<span class="badge bg-success">Activo</span>` : `<span class="badge bg-danger">Inactivo</span>`;
                const tipo = c.tipoProveedor === 0 ? `<span class="badge bg-primary">Interno</span>` : `<span class="badge bg-secondary">Externo</span>`;

                tbody.append(`
                    <tr>
                        <td class="p-1 ps-4">
                            <div class="fw-semibold">${c.nombreCompleto ?? ''}</div>
                            <small class="text-muted">${c.correo ?? ''}</small>
                        </td>
                        <td class="p-1">${c.cedula ?? ''}</td>
                        <td class="p-1">${c.telefono ?? ''}</td>
                        <td class="p-1">
                            <div>${c.numeroLicencia ?? ''}</div>
                            <small class="text-muted">${ c.fechaVencimientoLicencia ? moment(c.fechaVencimientoLicencia).format('DD/MM/YYYY') : '' }</small>
                        </td>
                        <td class="p-1">${tipo}</td>
                        <td class="p-1">${estado}</td>
                        <td class="text-end p-1 pe-4">
                            <button type="button" class="btn btn-sm btn-secondary" data-id="${c.id}" id="btnViewConductor">
                                <i class="fa-solid fa-eye"></i>
                            </button>                        
                            <button type="button" class="btn btn-sm btn-light" data-id="${c.id}" id="btnEditConductor">
                                <i class="fa-solid fa-pencil"></i>
                            </button>
                            <button type="button" class="btn btn-sm btn-danger" data-id="${c.id}" id="btnDisabledConductor">
                                <i class="fa-solid fa-ban"></i>
                            </button>
                        </td>
                    </tr>
                `);
            });
        }
    });

    conductoresTable.load();

    $("#filterBusqueda").keyup(function () {

        conductoresTable.load(1);

    });

    function renderStats() {
        $.ajax({
            url: '/Operaciones/Conductores/ObtenerDashboard',
            type: 'GET',
            success: function (response) {

                if (!response.success) {
                    mostrarAlerta('error', '', response.message);
                    return;
                }

                const data = response.data;
                $("#totalConductores").text(data.total);
                $("#totalInternos").text(data.internos);
                $("#totalExternos").text(data.externos);
                $("#licenciasVencidas").text(data.licenciasVencidas);
            },

            error: function (error) {
                showAlert('error', '', error.responseJSON?.message || 'Error al cargar dashboard');
            }
        });                

    }
       
    async function eliminarConductor(id) {

        if (!confirm('¿Eliminar conductor?'))
            return;

        const response = await $.post(
            '/Operaciones/Conductores/DeshabilitarConductor',
            { id });

        if (response.success) {

            toastr.success(response.message);

            cargarConductores(paginaActual);
        }
        else {

            toastr.error(response.message);
        }
    }

    $(document).on("click","#btnViewConductor",function () {
        const id = $(this).data("id");
        window.location.href = `/Operaciones/Conductores/Detalle/${id}`;
    });

    $(document).on("click","#btnEditConductor",function () {
        const id = $(this).data("id");
        window.location.href = `/Operaciones/Conductores/Editar/${id}`;
    });

    $(document).on("click","#btnDisabledConductor",function () {

        const id = $(this).data("id");

        Swal.fire({
            title: '¿Deshabilitar conductor?',
            icon: 'warning',
            showCancelButton: true,
            confirmButtonText: 'Sí'
        })
        .then((r) => {

            if (!r.isConfirmed)
                return;
            $.post(
                '/Operaciones/Conductores/DeshabilitarConductor',
                {
                    idConductor: id
                },
                function (response) {
                    if (response.success)
                    {
                        toastr.success(response.message);
                        conductoresTable.load();
                    }
                    else
                    {
                        toastr.error(response.message);
                    }
                });
        });
    });
</script>
}