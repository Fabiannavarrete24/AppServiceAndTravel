@{
    ViewData["Title"] = "Conductores";
    ViewData["Breadcrumb"] = "Gestión de conductores";
}

<!-- Stats -->
<div class="row g-3 mb-4">

    <div class="col-md-3">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body d-flex gap-3 align-items-center">
                <div class="rounded-circle d-flex align-items-center justify-content-center"
                     style="width:48px;height:48px;background:#dbeafe;color:#1d4ed8;">
                    <i class="bi bi-people-fill"></i>
                </div>
                <div>
                    <small class="text-muted">Total</small>
                    <div class="fw-bold fs-4" id="totalConductores">0</div>
                </div>
            </div>
        </div>
    </div>

    <div class="col-md-3">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body d-flex gap-3 align-items-center">
                <div class="rounded-circle d-flex align-items-center justify-content-center"
                     style="width:48px;height:48px;background:#d1fae5;color:#065f46;">
                    <i class="bi bi-person-check-fill"></i>
                </div>
                <div>
                    <small class="text-muted">Internos</small>
                    <div class="fw-bold fs-4" id="totalInternos">0</div>
                </div>
            </div>
        </div>
    </div>

    <div class="col-md-3">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body d-flex gap-3 align-items-center">
                <div class="rounded-circle d-flex align-items-center justify-content-center"
                     style="width:48px;height:48px;background:#fef3c7;color:#92400e;">
                    <i class="bi bi-person-badge-fill"></i>
                </div>
                <div>
                    <small class="text-muted" id="totalExternos">Externos</small>
                    <div class="fw-bold fs-4">0</div>
                </div>
            </div>
        </div>
    </div>

    <div class="col-md-3">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body d-flex gap-3 align-items-center">
                <div class="rounded-circle d-flex align-items-center justify-content-center"
                     style="width:48px;height:48px;background:#fee2e2;color:#991b1b;">
                    <i class="bi bi-exclamation-triangle-fill"></i>
                </div>
                <div>
                    <small class="text-muted">Licencias vencidas</small>
                    <div class="fw-bold fs-4" id="licenciasVencidas">0</div>
                </div>
            </div>
        </div>
    </div>

</div>

<!-- Tabla -->
<div class="card border-0 shadow-sm">

    <div class="card-header bg-white d-flex flex-wrap gap-3 align-items-center py-3">

        <span class="fw-semibold flex-grow-1">
            Conductores registrados
        </span>

        <!-- Filtro -->
        <div class="btn-group btn-group-sm">
            <a href="@Url.Action("Index")" class="btn btn-dark">
                Todos
            </a>

            <a class="btn btn-primary">
                Internos
            </a>

            <a class="btn btn-outline-secondary">
                Externos
            </a>
        </div>

        <!-- Buscar -->
        <form method="get" class="d-flex gap-2">

            <input type="hidden" name="tipo" value="" />

            <input type="search" name="busqueda" value="" class="form-control form-control-sm"
                   placeholder="Buscar conductor..." style="min-width:220px;" />

            <button class="btn btn-sm btn-outline-primary">
                <i class="bi bi-search"></i>
            </button>

        </form>
        <a asp-action="Create" class="btn btn-primary btn-sm">
            <i class="bi bi-plus-lg me-1"></i>Nuevo
        </a>

    </div>

    <div class="card-body p-0">

        <div class="text-center py-5 text-muted">
            <i class="bi bi-inbox" style="font-size:40px;opacity:.3;"></i>
            <p class="mt-2 mb-0">No hay conductores registrados.</p>
        </div>
        <div class="table-responsive">

            <table class="table table-hover mb-0" id="tbodyConductores">

                <thead>
                    <tr>
                        <th class="ps-4">Conductor</th>
                        <th>Cédula</th>
                        <th>Teléfono</th>
                        <th>Licencia</th>
                        <th>Tipo</th>
                        <th>Estado</th>
                        <th class="text-end pe-4">Acciones</th>
                    </tr>
                </thead>
                <tbody>
                </tbody>
                <ul class="pagination pagination-sm mb-0" id="paginacionConductores">
                </ul>
            </table>
        </div>
    </div>

</div>
@section Scripts {
    <script>
        $(document).ready(function () {

            cargarConductores();
        });
        let paginaActual = 1;
        let tipoActual = null;
        let busquedaActual = "";

        async function cargarConductores(page = 1) {

            paginaActual = page;

            const response = await $.get(
                '/Conductores/ObtenerConductores',
                {
                    pagina: page,
                    busqueda: busquedaActual,
                    tipo: tipoActual
                });

            renderStats(response);

            renderTabla(response.conductores);

            renderPaginacion(
                response.paginaActual,
                response.totalPaginas
            );
        }
        
        function renderStats(data) {

            $("#totalConductores").text(data.total);

            $("#totalInternos").text(data.internos);

            $("#totalExternos").text(data.externos);

            $("#licenciasVencidas").text(data.licenciasVencidas);
        }
        
        function renderTabla(items) {

            let html = '';

            if (!items.length) {

                html = `
            <tr>
                <td colspan="7" class="text-center py-4">
                    No hay registros
                </td>
            </tr>`;
            }
            else {

                items.forEach(c => {

                    html += `
                <tr>

                    <td class="ps-4">
                        <div class="fw-semibold">
                            ${c.nombreCompleto}
                        </div>
                        <small class="text-muted">
                            ${c.correo ?? ''}
                        </small>
                    </td>

                    <td>${c.cedula}</td>

                    <td>${c.telefono}</td>

                    <td>
                        <div>${c.numeroLicencia}</div>
                        <small class="text-muted">
                            ${formatDate(c.fechaVencimientoLicencia)}
                        </small>
                    </td>

                    <td>
                        ${badgeTipo(c.tipoProveedor)}
                    </td>

                    <td>
                        ${badgeEstado(c.activo)}
                    </td>

                    <td class="text-end pe-4">

                        <div class="d-flex justify-content-end gap-1">

                            <button class="btn btn-sm btn-outline-secondary"
                                    onclick="verConductor(${c.id})">

                                <i class="bi bi-eye"></i>

                            </button>

                            <button class="btn btn-sm btn-outline-primary"
                                    onclick="editarConductor(${c.id})">

                                <i class="bi bi-pencil"></i>

                            </button>

                            <button class="btn btn-sm btn-outline-danger"
                                    onclick="eliminarConductor(${c.id})">

                                <i class="bi bi-trash"></i>

                            </button>

                        </div>

                    </td>

                </tr>`;
                });
            }

            $("#tbodyConductores").html(html);
        }
        
        function renderPaginacion(actual, total) {

            let html = '';

            for (let i = 1; i <= total; i++) {

                html += `
            <li class="page-item ${i === actual ? 'active' : ''}">
                <a class="page-link"
                   href="javascript:void(0)"
                   onclick="cargarConductores(${i})">
                    ${i}
                </a>
            </li>`;
            }

            $("#paginacionConductores").html(html);
        }
        
        async function eliminarConductor(id) {

            if (!confirm('¿Eliminar conductor?'))
                return;

            const response = await $.post(
                '/Conductores/EliminarConductor',
                { id });

            if (response.success) {

                toastr.success(response.message);

                cargarConductores(paginaActual);
            }
            else {

                toastr.error(response.message);
            }
        }
        
        async function verConductor(id) {

            const conductor = await $.get(
                '/Conductores/ObtenerConductor',
                { id });

            llenarFormulario(conductor);

            $('#modalConductor').modal('show');
        }
        
        $("#txtBusqueda").on('keyup', function () {

            busquedaActual = $(this).val();

            cargarConductores(1);
        });
        
        function filtrarInternos() {

            tipoActual = 1;

            cargarConductores(1);
        }
        
        function filtrarExternos() {

            tipoActual = 2;

            cargarConductores(1);
        }
        
        function filtrarTodos() {

            tipoActual = null;

            cargarConductores(1);
        }
    </script>
}