<!-- Tabla -->
<div class="card border-0 shadow-sm">

    <div class="card-header bg-white d-flex flex-wrap gap-3 align-items-center py-3">

        <span class="fw-semibold flex-grow-1">
            Conductores registrados
        </span>

        <!-- Filtro -->
        <div class="btn-group btn-group-sm">
            <a href="@Url.Action("Index")"
               class="btn btn-dark">
                Todos
            </a>

            <a href="@Url.Action("Index", new { tipo = AppServiceAndTravel.Models.TipoProveedor.Interno })"
               class="btn btn-primary">
                Internos
            </a>

            <a href="@Url.Action("Index", new { tipo = AppServiceAndTravel.Models.TipoProveedor.Externo })"
               class="btn btn-outline-secondary">
                Externos
            </a>
        </div>

        <!-- Buscar -->
        <form method="get" class="d-flex gap-2">

            <input type="hidden" name="tipo" value="" />

            <input type="search"
                   name="busqueda"
                   value=""
                   class="form-control form-control-sm"
                   placeholder="Buscar conductor..."
                   style="min-width:220px;" />

            <button class="btn btn-sm btn-outline-primary">
                <i class="bi bi-search"></i>
            </button>

        </form>
        <a asp-action="Create" class="btn btn-primary btn-sm">
            <i class="bi bi-plus-lg me-1"></i>Nuevo
        </a>

    </div>

    <div class="card-body p-0">

        <div class="text-center py-5 text-muted">
            <i class="bi bi-inbox" style="font-size:40px;opacity:.3;"></i>
            <p class="mt-2 mb-0">No hay conductores registrados.</p>
        </div>
        <div class="table-responsive">

            <table class="table table-hover mb-0">

                <thead>
                    <tr>
                        <th class="ps-4">Conductor</th>
                        <th>Cédula</th>
                        <th>Teléfono</th>
                        <th>Licencia</th>
                        <th>Tipo</th>
                        <th>Estado</th>
                        <th class="text-end pe-4">Acciones</th>
                    </tr>
                </thead>

                <tbody>

                   @*  @foreach (var c in Model)
                    {
                        
                    } *@
                    <tr>

                        <td class="ps-4">
                            <div class="fw-semibold">NombreCompleto</div>
                            <small class="text-muted">correo</small>
                        </td>

                        <td>Cedula</td>

                        <td>Telefono</td>

                        <td>
                            <div>NumeroLicencia</div>
                            <small class="text-muted">
                                Vence:
                                @* @c.FechaVencimientoLicencia.ToString("dd/MM/yyyy") *@
                            </small>
                        </td>

                        <td>
                            <span class="badge ">
                                @* @c.TipoProveedor *@
                            </span>
                        </td>

                        <td>
                            <span class="badge bg-success">Activo</span>
                            @*                                 @if (c.Activo)
                                {
                                    
                                }
                                else
                                {
                                    
                                } *@
