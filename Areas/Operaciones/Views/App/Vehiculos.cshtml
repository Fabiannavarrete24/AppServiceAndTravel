    }

    async function guardarVehiculo() {        

        const response = await $.ajax({
            url: '/Operaciones/Vehiculos/GuardarVehiculo',
            method: 'POST',
            contentType: 'application/json',
            data: JSON.stringify(model)
        });

        if (response.success) {
            toastr.success(response.message);
            cargarVehiculos();
            $('#modalVehiculo').modal('hide');
        }
    }

    async function cargarKPIs() {

        const response = await $.get('/Operaciones/Vehiculos/ObtenerKPIs');

        if (!response.success)
            return;
    
        const data = response.data;
        $("#kpiActivos").text(data.activos);
        $("#kpiInactivos").text(data.inactivos);
        $("#kpiMantenimiento").text(data.mantenimiento);
        $("#kpiAlertas").text(data.alertas);
    }

    $(".filtroEstado").click(function () {

        $("#filterEstadoVehiculo")
            .val($(this).data("estado"));

        vehiculosTable.load(1);

    });

    $("#txtBuscarVehiculo").on("keyup", function () {

        clearTimeout(window.searchVehiculo);

        const valor = $(this).val();

        window.searchVehiculo = setTimeout(() => {

            if (
                valor.length >= 5 ||
                valor.length === 0
            ) {

                vehiculosTable.load(1);

            }

        }, 1000);

    });
</script>
