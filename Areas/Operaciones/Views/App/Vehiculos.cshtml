<div class="card border-0 shadow-sm rounded-4">
  <div class="card-header bg-white border-0 py-3 px-4 d-flex flex-wrap align-items-center gap-3">
    <span class="fw-semibold flex-grow-1">Flota de vehículos</span>

    <div class="btn-group btn-group-sm">
      <a href="@Url.Action("Index")" class="btn btn-dark">Todos</a>
      <a href="@Url.Action("Index", new { estado = AppServiceAndTravel.Models.EstadoVehiculo.Activo })"
         class="btn btn-success">Activos</a>
      <a href="@Url.Action("Index", new { estado = AppServiceAndTravel.Models.EstadoVehiculo.Inactivo })"
         class="btn btn-danger">Inactivos</a>
      <a href="@Url.Action("Index", new { estado = AppServiceAndTravel.Models.EstadoVehiculo.EnMantenimiento })"
         class="btn btn-warning">Mantenimiento</a>
    </div>

    <form method="get" class="d-flex gap-2">
      @* @if (ViewBag.EstadoFiltro != null) *@
        <input type="hidden" name="estado" value="@ViewBag.EstadoFiltro" />
      <input type="search" name="busqueda" value="@ViewBag.Busqueda"
             class="form-control form-control-sm rounded-3" placeholder="Buscar placa, marca…" style="min-width:180px;" />
      <button class="btn btn-sm btn-outline-primary rounded-3"><i class="bi bi-search"></i></button>
    </form>

