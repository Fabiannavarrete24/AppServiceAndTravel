@{
    ViewData["Title"] = "Nuevo Servicio";
    ViewData["Breadcrumb"] = "Generar servicio desde cotización aprobada";
}
<div class="row g-4">
    <!-- Formulario -->
    <div class="col-lg-8">
        <div class="card">
            <div class="card-header bg-white py-3 d-flex align-items-center gap-2">
                <i class="bi bi-truck text-primary fs-5"></i>
                <span class="fw-semibold">Datos del Servicio</span>
            </div>
            <div class="card-body">
                <form id="formServicio" class="row">
                    @Html.AntiForgeryToken()
                    <input type="hidden" id="idDetalleCotizacion" />
                    <input type="hidden" id="idCotizacion" />
                    <div class="col-12">
                        <h6 class="fw-semibold small text-uppercase text-muted mb-2">Cotizaciones</h6>
                        <div class="row">
                            <div class="col-sm-6">
                                <label class="form-label fw-semibold">
                                    Cotización <span class="text-danger">*<span>
                                </label>

                                <select id="selectCotizacion" class="form-select" required>
                                    <option value="">
                                        Seleccione una cotización
                                    </option>
                                </select>
                            </div>

                            <div class="col-sm-6">
                                <label class="form-label fw-semibold">
                                    Detalle <span class="text-danger">*<span>
                                </label>

                                <select id="selectDetalleCotizacion" class="form-select" required disabled>
                                    <option value="">
                                        Seleccione un detalle
                                    </option>
                                </select>
                            </div>
                        </div>
                    </div>
                    <div class="col-12">
                        <h6 class="fw-semibold small text-uppercase text-muted mb-2">Ruta</h6>
                        <div class="row g-3 mb-3">
                            <div class="col-md-6">
                                <label class="form-label fw-semibold small">Origen <span class="text-danger">*<span></label>
                                <div class="input-group">
                                    <span class="input-group-text bg-light border-end-0"><i
                                        class="bi bi-geo-alt text-muted"></i></span>
                                        <input id="origen" class="form-control border-start-0 rounded-end-3" />
                                    </div>
                                    <span id="Origen" class="text-danger small"></span>
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label fw-semibold small">Destino <span class="text-danger">*<span></label>
                                    <div class="input-group">
                                        <span class="input-group-text bg-light border-end-0">
                                            <i class="bi bi-geo-alt-fill text-primary"></i>
                                        </span>
                                        <input id="destino" class="form-control border-start-0 rounded-end-3" />
                                    </div>
                                    <span id="destino" class="text-danger small"></span>
                                </div>
                            </div>
                    </div>
                    <div class="col-12">
                        <h6 class="fw-semibold small text-uppercase text-muted mb-2">Vehiculo</h6>
                        <div class="row g-3 mb-3">
                            <div class="col-md-6">
                                <label class="form-label fw-semibold small">Tipo Vehiculo</label>
                                <div class="input-group">
                                    <input id="tipoVehiculo" class="form-control border-start-0 rounded-end-3" />
                                </div>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label fw-semibold small">Vehiculo</label>
                                <div class="input-group">
                                    <select id="Vehiculo" class="form-control border-start-0 rounded-end-3">

                                    </select>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="col-12">
                        <h6 class="fw-semibold small text-uppercase text-muted mb-2">Conductor</h6>
                        <div class="row g-3 mb-3">
                            <div class="col-md-6">
                                <label class="form-label fw-semibold small">Conductor <span class="text-danger">*<span></label>
                                <div class="input-group">
                                    <input id="Conductor" class="form-control border-start-0 rounded-end-3" />
                                </div>
                            </div>
                        </div>
                    </div>                        
                    <div class="col-12">
                        <h6 class="fw-semibold small text-uppercase text-muted mb-2">Detalles</h6>
                        <div class="row g-3 mb-3">
                            <div class="col-sm-3">
                                <label class="form-label fw-semibold small">Inicio del servicio <span class="text-danger">*<span></label>
                                <input id="fechaInicioServicio" type="date" class="form-control rounded-3"
                                    min="@DateTime.Today.ToString("yyyy-MM-dd")" required />
                            </div>
                            <div class="col-sm-3">
                                <label class="form-label fw-semibold small">Final del servicio <span class="text-danger">*<span></label>
                                <input id="fechaFinalServicio" type="date" class="form-control rounded-3"
                                    min="@DateTime.Today.ToString("yyyy-MM-dd")" required />
                            </div>
                            <div class="col-sm-2">
                                <label for="diasServicio" class="form-label fw-semibold small">Dias de Servicio</label>
                                <input id="diasServicio" type="number" class="form-control rounded-3" min="1" max="99"
                                    value="1" disabled />
                            </div>
                            <div class="col-sm-2">
                                <label for="numPasajeros" class="form-label fw-semibold small">N° de pasajeros</label>
                                <input id="numPasajeros" type="number" class="form-control rounded-3" min="1" max="99"
                                    value="1" disabled />
                            </div>
                            <div class="col-sm-2 d-flex flex-column justify-content-between">
                                <label for="disponibilidad" class="form-label fw-semibold small">Disponibilidad</label>
                                <div class="form-check form-switch">
                                    <input class="form-check-input" type="checkbox" role="switch" id="disponibidad"
                                        disabled />
                                </div>
                            </div>
                            <div class="col-12">
                                <label class="form-label fw-semibold small">Observaciones</label>
                                <textarea id="observaciones" class="form-control rounded-3" rows="3" cols="6"
                                        placeholder="Instrucciones especiales, puntos de encuentro"></textarea>
                            </div>
                        </div>
                    </div>
                    <div class="col-12">
                        <h6 class="fw-semibold small text-uppercase text-muted mb-2">Costos del Servicio</h6>
                        <div class="row g-3 mb-3">
                            <div class="col-sm-6">
                                <label class="form-label fw-semibold small">Costos <span class="text-danger">*<span></label>
                                <div class="input-group">
                                    <span class="input-group-text bg-light fw-semibold">$</span>
                                    <input id="costo" type="text" class="form-control" step="1000" min="0"
                                        placeholder="0" />
                                    <span class="input-group-text rounded-end-3 bg-light">COP</span>
                                </div>

                            </div>
                        </div>
                    </div>
                    <div class="col-12">
                        <div class="row gap-2">
                            <!-- Panel de validación en tiempo real -->
                            <div id="panelValidacion" class="mb-4">
                                <div class="d-flex align-items-center gap-2 mb-2">
                                    <span id="validacionSpinner"
                                        class="spinner-border spinner-border-sm text-primary"></span>
                                    <strong id="validacionTitulo" class="fw-semibold">Validando vehículo y
                                        conductor…</strong>
                                    </div>
                                    <div id="validacionContenido"></div>
                                </div>

                                <div class="d-flex gap-3">
                                    <button type="button" id="btnValidar" class="btn btn-outline-primary d-none"
                                            onclick="validarVehiculo()">
                                        <i class="bi bi-shield-check me-1"></i>Validar documentación
                                    </button>
                                    <button type="submit" class="btn btn-primary px-4">
                                        <i class="bi bi-truck me-2"></i>Generar Servicio y Notificar
                                    </button>
                                    <a asp-action="Index" class="btn btn-outline-secondary">Cancelar</a>
                                </div>
                            </div>
                    </div>
                            @* <div class="alert alert-danger rounded-3 mb-4">
                        <div class="fw-semibold mb-2">
                            <i class="bi bi-shield-exclamation me-2"></i> El vehículo no pasó la validación:
                        </div>
                            <div class="d-flex align-items-center gap-2">
                                <i class="bi bi-x-circle-fill text-danger"></i> err
                            </div>
                        </div>
                        <div class="alert alert-warning rounded-3 mb-4">
                            <div class="fw-semibold mb-2">
                                <i class="bi bi-exclamation-triangle me-2"></i>Advertencias (no bloquean el servicio):
                            </div>
                                <div>adv</div>
                            </div> *@
                            <!-- Cotización -->
                        </form>
                    </div>
                </div>
            </div>

            <!-- Panel lateral -->
            <div class="col-lg-4">
                <!-- Info de la cotización -->
                <div class="card mb-3" id="infoCotizacion">
                    <div class="card-header bg-white py-3">
                        <span class="fw-semibold"><i class="bi bi-file-earmark-text me-2 text-primary"></i>Cotización</span>
                    </div>
                    <div class="card-body small" id="infoCotizacionBody"></div>
                </div>

                <!-- Qué pasará -->
                <div class="card">
                    <div class="card-header bg-white py-3">
                        <span class="fw-semibold"><i class="bi bi-send me-2 text-primary"></i>Notificaciones automáticas</span>
                    </div>
                    <div class="card-body">
                        <div class="d-flex align-items-start gap-3 mb-3">
                            <div class="rounded-circle d-flex align-items-center justify-content-center flex-shrink-0"
                                 style="width:36px;height:36px;background:#dbeafe;color:#1e40af;">
                                <i class="bi bi-envelope"></i>
                            </div>
                            <div>
                                <div class="fw-semibold small">correo de confirmadaación</div>
                                <div class="text-muted" style="font-size:12px;">Se enviará al correo del cliente con todos los
                                    detalles del servicio.</div>
                                </div>
                            </div>
                            <div class="d-flex align-items-start gap-3">
                                <div class="rounded-circle d-flex align-items-center justify-content-center flex-shrink-0"
                                     style="width:36px;height:36px;background:#d1fae5;color:#065f46;">
                                    <i class="bi bi-whatsapp"></i>
                                </div>
                                <div>
                                    <div class="fw-semibold small">WhatsApp</div>
                                    <div class="text-muted" style="font-size:12px;">Mensaje automático via CallMeBot con los datos
                                        del vehículo y conductor.</div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Checklist de validación -->
                        <div class="card mt-3">
                            <div class="card-header bg-white py-3">
                                <span class="fw-semibold"><i class="bi bi-shield-check me-2 text-primary"></i>Qué se valida</span>
                            </div>
                            <div class="card-body">
                                @foreach (var item in new[] {
                    ("Estado del vehículo activo", "bi-truck"),
                    ("SOAT vigente", "bi-file-earmark-check"),
                    ("Revisión técnico-mecánica", "bi-wrench"),
                    ("Seguro del vehículo", "bi-shield"),
                    ("Licencia del conductor", "bi-person-badge")
                })
                                {
                                    <div class="d-flex align-items-center gap-2 mb-2">
                                        <i class="bi @item.Item2 text-primary"></i>
                                        <small>@item.Item1</small>
                                    </div>
                                }
                            </div>
                        </div>
                    </div>
                </div>

                @section Scripts {
                    <partial name="_ValidationScriptsPartial" />
                    <script>
                        $(document).ready(function () {

                            cargarCotizaciones();

                        });
                        function cargarCotizaciones() {

                            $.get(
                                "/Comercial/Cotizacion/GetCotizacionesAprobadas",
                                function (response) {

                                    let combo = $("#selectCotizacion");

                                    combo.empty();

                                    combo.append(`
                                        <option value="">
                                            Seleccione una cotización
                                        </option>
                                    `);
                                    response.data.forEach(c => {
                                        combo.append(`
                                        <option value="${c.idCotizacion}">
                                            #${c.idCotizacion}
                                            - ${c.cliente}
                                        </option>
                                    `);

                                    });

                                }
                            );
                        }

                        $("#selectCotizacion").change(function () {

                            let idCotizacion = $(this).val();

                            if (!idCotizacion)
                                return;

                            cargarDetalles(idCotizacion);

                        });

                        function cargarDetalles(idCotizacion) {

                            $.get(
                                "/Operaciones/Servicios/GetDetallesCotizacion",
                                {
                                    idCotizacion
                                },
                                function (response) {

                                    let combo =
                                        $("#selectDetalleCotizacion");
                                    combo.prop("disabled", false);
                                    combo.empty();
                                    combo.append(`
                                    <option value="">
                                        Seleccione un detalle
                                    </option>
                                `);

                                    response.data.forEach(d => {
                                        combo.append(`
                                        <option value="${d.idDetalleCotizacion}">
                                            ${d.descripcion}
                                        </option>
                                    `);

                                    });

                                }
                            );
                        }

                        $("#selectDetalleCotizacion").change(function () {

                            let idDetalle = $(this).val();

                            if (!idDetalle)
                                return;

                            cargarInformacionDetalle(idDetalle);

                        });
                        function cargarInformacionDetalle(idDetalle) {

                            $.get(
                                "/Operaciones/Servicios/GetDetalleServicio",
                                {
                                    idDetalleCotizacion: idDetalle
                                },
                                function (response) {

                                    let d = response.data;

                                    $("#idCotizacion").val(d.idCotizacion);
                                    $("#idDetalleCotizacion").val(d.idDetalleCotizacion);
                                    $("#origen").val(d.origen);
                                    $("#destino").val(d.destino);
                                    $("#tipoVehiculo").val(d.tipoVehiculo);
                                    $("#fechaInicioServicio").val(moment(d.fechaInicio).format("YYYY-MM-DD"));
                                    $("#fechaFinalServicio").val(moment(d.fechaFin).format("YYYY-MM-DD"));
                                    $("#numPasajeros").val(d.numPasajeros);
                                    $("#costo").val(d.costo);
                                    $("#observaciones").val(d.observaciones);
                                }
                            );
                        }

                        function cargarDetallesAprobados() {

                            $.get('/Comercial/Servicio/GetDetallesAprobados', function (response) {

                                let combo = $("#selectDetalleCotizacion");

                                combo.empty();

                                combo
                                .append(`
                                    <option value="">
                                        Seleccione un servicio aprobado
                                    </option>
                                `);

                                response.data.forEach(item => {

                                    combo
                                    .append(`
                                        <option value="${item.idDetalleCotizacion}">
                                            ${item.cliente}
                                            | ${item.origen}
                                            → ${item.destino}
                                            | ${item.fechaServicio}
                                        </option>
                                    `);
                                });
                            });
                        }
                        $("#selectDetalleCotizacion").change(function () {

                            let id = $(this).val();

                            if (!id)
                                return;

                            $.get('/Comercial/Servicio/GetDetalleCotizacion',
                                {
                                    idDetalleCotizacion: id
                                },
                                function (response) {
                                    let d = response.data;
                                    $("#infoCotizacion").show();
                                    $("#infoCotizacionBody")
                                        .html(`
                                            <div class="mb-2">
                                                <strong>Cliente:</strong><br>
                                                ${d.cliente}
                                            </div>
                                            <div class="mb-2">
                                                <strong>Ruta:</strong><br>
                                                ${d.origen} → ${d.destino}
                                            </div>
                                            <div class="mb-2">
                                                <strong>Fecha:</strong><br>
                                                ${moment(d.fechaServicio).format("DD/MM/YYYY")}
                                            </div>
                                            <div class="mb-2">
                                                <strong>Pasajeros:</strong><br>
                                                ${d.numPasajeros}
                                            </div>
                                            <div class="mb-2">
                                                <strong>Vehículo solicitado:</strong><br>
                                                ${d.tipoVehiculo}
                                            </div>
                                        `);
                                });
                        });

                        function validarVehiculo() {
                            $.ajax({
                                url: '/Comercial/Servicio/ValidarVehiculo',
                                type: 'POST',
                                data: {
                                    vehiculoId: $("#selectVehiculo").val(),
                                    conductorId: $("#selectConductor").val()
                                },
                                success: function (data) {
                                    // mostrar validación
                                }
                            });
                        }
                        
                        $("#formServicio").submit(function (e) {
                            e.preventDefault();
                            $.ajax({
                                url: '/Comercial/Servicio/CrearServicio',
                                type: 'POST',
                                data: {
                                    idDetalleCotizacion: $("#selectDetalleCotizacion").val(),
                                    idVehiculo: $("#selectVehiculo").val(),
                                    idConductor: $("#selectConductor").val(),
                                    fechaServicio: $("#fechaServicio").val(),
                                    observaciones: $("#observaciones").val()
                                },
                                beforeSend: function () {
                                    showLoader();
                                },
                                success: function (response) {
                                    if (response.success) {
                                        showAlert( "success", "", response.message );
                                        location.href = "/Comercial/App/Servicios";
                                    }
                                },
                                complete: function () {
                                    hideLoader();
                                },
                                error: function (error) {
                                    showAlert("error","",error.responseJSON.message);
                                }
                            });
                        });

                    </script>
                }
