@section Scripts {
<partial name="_ValidationScriptsPartial" />
<script>
    // Mostrar botón de validación cuando se seleccionan vehículo y conductor
    function checkBtnValidar() {
        var v = document.getElementById('selectVehiculo').value;
        var c = document.getElementById('selectConductor').value;
        document.getElementById('btnValidar').classList.toggle('d-none', !(v && c));
        document.getElementById('panelValidacion').classList.add('d-none');
    }

    document.getElementById('selectVehiculo').addEventListener('change', checkBtnValidar);
    document.getElementById('selectConductor').addEventListener('change', checkBtnValidar);

    async function validarVehiculo() {
        var vehiculoId = document.getElementById('selectVehiculo').value;
        var conductorId = document.getElementById('selectConductor').value;

        var panel = document.getElementById('panelValidacion');
        var spinner = document.getElementById('validacionSpinner');
        var titulo = document.getElementById('validacionTitulo');
        var contenido = document.getElementById('validacionContenido');

        panel.classList.remove('d-none');
        spinner.classList.remove('d-none');
        titulo.textContent = 'Validando documentación…';
        contenido.innerHTML = '';

        const token = document.querySelector('input[name="__RequestVerificationToken"]').value;

        const resp = await fetch('@Url.Action("ValidarVehiculo", "Servicio")', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json', 'RequestVerificationToken': token },
            body: JSON.stringify({ vehiculoId: parseInt(vehiculoId), conductorId: parseInt(conductorId) })
        });

        const data = await resp.json();
        spinner.classList.add('d-none');

        if (data.exitoso) {
            titulo.innerHTML = '<i class="bi bi-shield-check text-success me-2"></i>Validación exitosa';
            var html = '<div class="alert alert-success py-2 small mb-2">El vehículo y conductor están en regla.</div>';
            if (data.advertencias.length > 0) {
                html += '<div class="alert alert-warning py-2 small">';
                data.advertencias.forEach(a => { html += '<div>' + a + '</div>'; });
                html += '</div>';
            }
            contenido.innerHTML = html;
        } else {
            titulo.innerHTML = '<i class="bi bi-shield-exclamation text-danger me-2"></i>Validación fallida';
            var html = '<div class="alert alert-danger py-2 small">';
            data.errores.forEach(e => {
                html += '<div class="d-flex align-items-center gap-2"><i class="bi bi-x-circle-fill"></i>' + e + '</div>';
            });
            html += '</div>';
            contenido.innerHTML = html;
        }
    }

    // Si hay cotización preseleccionada, marcarla
    @if (Model.CotizacionId > 0)
    {
        <text>document.getElementById('selectCotizacion').value = '@Model.CotizacionId';</text>
    }
    @if (Model.FechaServicio != default)
    {
        <text>
        document.querySelector('input[name="FechaServicio"]').value =
            '@Model.FechaServicio.ToString("yyyy-MM-ddTHH:mm")';
        </text>
    }
</script>
} *@
