@* @model AppServiceAndTravel.Models.Vehiculo
@{
    bool esEdicion = Model.Id > 0;
    ViewData["Title"] = esEdicion ? $"Editar Vehículo {Model.Placa}" : "Nuevo Vehículo";
    ViewData["Breadcrumb"] = esEdicion ? "Vehículos / Editar" : "Vehículos / Nuevo";
} *@

<div class="row g-4">
  <div class="col-lg-8">
    <div class="card border-0 shadow-sm rounded-4">
      <div class="card-header bg-white border-0 px-4 pt-4 pb-0 d-flex align-items-center gap-2">
        <div class="rounded-3 d-flex align-items-center justify-content-center"
             style="width:36px;height:36px;background:#dbeafe;font-size:18px;color:#1d4ed8;">
          <i class="bi bi-truck"></i>
        </div>
        <div>
          <h5 class="mb-0 fw-semibold">Editar vehículo</h5>
          <small class="text-muted">Complete la información del vehículo y sus documentos</small>
        </div>
      </div>
      <div class="card-body px-4 pb-4 pt-3">
        <form asp-action="Edit" method="post">
          @* @Html.AntiForgeryToken() *@
          @* @if (esEdicion) {  } *@
          <input type="hidden" />
          <div class="alert alert-danger rounded-3 py-2 small"></div>

          <!-- Identificación -->
          <h6 class="fw-semibold text-muted small text-uppercase mb-3 mt-2">
            <i class="bi bi-card-text me-1"></i>Identificación
          </h6>
          <div class="row g-3 mb-4">
            <div class="col-md-4">
              <label class="form-label fw-semibold small">Placa <span class="text-danger">*</span></label>
              <input class="form-control rounded-3 text-uppercase" placeholder="ABC-123"
                     required />
              <span class="text-danger small"></span>
            </div>
            <div class="col-md-4">
              <label class="form-label fw-semibold small">Marca <span class="text-danger">*</span></label>
              <input class="form-control rounded-3" placeholder="Ej: Mercedes-Benz" required />
              <span class="text-danger small"></span>
            </div>
            <div class="col-md-4">
              <label class="form-label fw-semibold small">Modelo <span class="text-danger">*</span></label>
              <input class="form-control rounded-3" placeholder="Ej: Sprinter 515" required />
              <span class="text-danger small"></span>
            </div>
            <div class="col-md-4">
              <label  class="form-label fw-semibold small">Año <span class="text-danger">*</span></label>
              <input type="number" class="form-control rounded-3"
                     min="1990" max="@(DateTime.Today.Year + 1)" required />
              <span class="text-danger small"></span>
            </div>
            <div class="col-md-4">
              <label class="form-label fw-semibold small">Capacidad pasajeros</label>
              <input type="number" class="form-control rounded-3" min="0" />
            </div>
            <div class="col-md-4">
              <label  class="form-label fw-semibold small">Cap. carga (ton)</label>
              <input  type="number" class="form-control rounded-3" step="0.5" min="0" />
            </div>
            <div class="col-md-4">
              <label class="form-label fw-semibold small">Estado <span class="text-danger">*</span></label>
              <select class="form-select rounded-3" asp-items="Html.GetEnumSelectList<AppServiceAndTravel.Models.EstadoVehiculo>()">
              </select>
            </div>
          </div>

          <hr class="my-3" />

          <!-- Documentos -->
          <h6 class="fw-semibold text-muted small text-uppercase mb-3">
            <i class="bi bi-file-earmark-check me-1"></i>Vencimiento de documentos
          </h6>
          <div class="row g-3 mb-4">
            <div class="col-md-4">
              <label class="form-label fw-semibold small">
                SOAT <span class="text-danger">*</span>
              </label>
              <div class="input-group">
                <span class="input-group-text bg-light border-end-0" style="border-radius:12px 0 0 12px;">
                  <i class="bi bi-calendar3 text-muted"></i>
                </span>
                <input  type="date" class="form-control border-start-0"
                       style="border-radius:0 12px 12px 0;" required />
              </div>
              <span  class="text-danger small"></span>
            </div>
            <div class="col-md-4">
              <label  class="form-label fw-semibold small">
                Tecno-mecánica <span class="text-danger">*</span>
              </label>
              <div class="input-group">
                <span class="input-group-text bg-light border-end-0" style="border-radius:12px 0 0 12px;">
                  <i class="bi bi-wrench text-muted"></i>
                </span>
                <input  type="date" class="form-control border-start-0"
                       style="border-radius:0 12px 12px 0;" required />
              </div>
              <span  class="text-danger small"></span>
            </div>
            <div class="col-md-4">
              <label  class="form-label fw-semibold small">
                Seguro <span class="text-danger">*</span>
              </label>
              <div class="input-group">
                <span class="input-group-text bg-light border-end-0" style="border-radius:12px 0 0 12px;">
                  <i class="bi bi-shield text-muted"></i>
                </span>
                <input  type="date" class="form-control border-start-0"
                       style="border-radius:0 12px 12px 0;" required />
              </div>
              <span  class="text-danger small"></span>
            </div>
          </div>

          <!-- Observaciones -->
          <div class="mb-4">
            <label class="form-label fw-semibold small">Observaciones</label>
            <textarea  class="form-control rounded-3" rows="3"
                      placeholder="Condiciones especiales, restricciones, notas del vehículo…"></textarea>
          </div>

          <div class="d-flex gap-3">
            <button type="submit" class="btn btn-primary px-4 rounded-3">
              <i class="bi bi-save me-2"></i>Guardar cambios
            </button>
            <a asp-action="Index" class="btn btn-outline-secondary rounded-3">Cancelar</a>
          </div>
        </form>
      </div>
    </div>
  </div>

  <div class="col-lg-4">
    <div class="card border-0 shadow-sm rounded-4">
      <div class="card-body p-4">
        <h6 class="fw-semibold mb-3"><i class="bi bi-info-circle me-2 text-primary"></i>Documentos requeridos</h6>
        @foreach (var (icon, doc, desc) in new[] {
          ("bi-file-earmark-check", "SOAT", "Seguro Obligatorio de Accidentes de Tránsito"),
          ("bi-wrench-adjustable", "Revisión Técnico-Mecánica", "Certificado de revisión periódica obligatoria"),
          ("bi-shield-shaded", "Seguro del Vehículo", "Póliza de seguro todo riesgo o responsabilidad civil")
        })
        {
          <div class="d-flex gap-3 mb-3">
            <div class="rounded-3 d-flex align-items-center justify-content-center flex-shrink-0"
                 style="width:34px;height:34px;background:#dbeafe;font-size:16px;color:#1d4ed8;">
              <i class="bi @icon"></i>
            </div>
            <div>
              <div class="fw-semibold small">@doc</div>
              <div class="text-muted" style="font-size:12px;">@desc</div>
            </div>
          </div>
        }
        <div class="alert alert-warning rounded-3 small py-2 mt-2 mb-0">
          <i class="bi bi-exclamation-triangle me-1"></i>
          El sistema alertará 30 días antes del vencimiento de cada documento.
        </div>
      </div>
    </div>
  </div>
</div>

@section Scripts { <partial name="_ValidationScriptsPartial" /> }
