@{
  ViewData["Title"] = "Vehículos";
  ViewData["Breadcrumb"] = "Vehículos / Nuevo";
}
@section Styles {
  <style>
    .placa-colombia {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-width: 120px;
      height: 45px;
      background: #f8d117;
      border: 4px solid #2d2d2d;
      border-radius: 6px;
      font-family: 'Arial Black', sans-serif;
      font-size: 18px;
      font-weight: bold;
      letter-spacing: 2px;
      color: #000;
    }
  </style>
}
<div class="row g-4">

  <div class="col-lg-8">
    <div class="card border-0 shadow-sm mb-3">
      <div class="card-body d-flex justify-content-between align-items-center">
        <div class="d-flex gap-1">
          <button type="button" class="btn btn-primary" id="btnNuevo">
            <i class="fa-regular fa-square-plus"></i>
          </button>
          <button type="button" class="btn btn-success" id="btnGuardar">
            <i class="fa-solid fa-save"></i>
          </button>
          <button type="button" class="btn btn-warning" id="btnEditar">
            <i class="fa-regular fa-pen-to-square"></i>
          </button>
          <button type="button" class="btn btn-danger" id="btnDeshabilitar">
            <i class="fa-solid fa-ban"></i>
          </button>
        </div>
        <div id="placaPreview" class="placa-colombia">
          ABC-123
        </div>
        <div>
          <input id="txtBuscarVehiculo" class="form-control"
                 placeholder="Buscar por placa, VIN, motor o propietario..." />
        </div>
      </div>
    </div>
    <div class="card">
      <div class="card-header py-3">
        <ul class="nav nav-pills" id="pills-tab" role="tablist">
          <li class="nav-item" role="presentation">
            <button class="nav-link active" id="general-tab" data-bs-toggle="pill" data-bs-target="#general"
                    type="button" role="tab" aria-controls="general" aria-selected="true">
              General
            </button>
          </li>
          <li class="nav-item" role="presentation">
            <button class="nav-link" id="propietario-tab" data-bs-toggle="pill" data-bs-target="#propietario"
                    type="button" role="tab" aria-controls="propietario" aria-selected="false">
              Propietario
            </button>
          </li>
          <li class="nav-item" role="presentation">
            <button class="nav-link" id="motorCaracteristicas-tab" data-bs-toggle="pill"
                    data-bs-target="#motorCaracteristicas" type="button" role="tab" aria-controls="motorCaracteristicas"
                    aria-selected="false">
              Motor y Caracteristicas
            </button>
          </li>
          <li class="nav-item" role="presentation">
            <button class="nav-link" id="matricula-tab" data-bs-toggle="pill" data-bs-target="#matricula" type="button"
                    role="tab" aria-controls="matricula" aria-selected="false">
              matricula
            </button>
          </li>
          <li class="nav-item" role="presentation">
            <button class="nav-link" id="Documentos-tab" data-bs-toggle="pill" data-bs-target="#documentos"
                    type="button" role="tab" aria-controls="Documentos" aria-selected="false">
              Documentos
            </button>
          </li>
          <li class="nav-item" role="presentation">
            <button class="nav-link" id="configuracion-tab" data-bs-toggle="pill" data-bs-target="#configuracion"
                    type="button" role="tab" aria-controls="configuracion" aria-selected="false">
              Configuración Especial
            </button>
          </li>
        </ul>        
      </div>
      <div class="card-body">
        <div class="tab-content" id="pills-tabContent">
          <div class="tab-pane fade show active" id="general" role="tabpanel" aria-labelledby="general-tab"
               tabindex="0">
            <div class="row gy-2">
              <h6 class="fw-semibold small text-muted mb-2">GENERAL</h6>
              <div class="col-md-3">
                <label class="form-label">Placa</label>
                <input type="hidden" id="idVehiculo" class="form-control" value="0" />
                <input id="Placa" class="form-control text-uppercase" maxlength="10" placeholder="ABC123" />
              </div>
              <div class="col-md-3">
                <label class="form-label">Licencia de transito</label>
                <input id="LicenciaTransito" class="form-control" />
              </div>
              <div class="col-md-3">
                <label class="form-label">Estado</label>
                <Select id="Estado" class="form-select"></Select>
              </div>
              <div class="col-md-3">
                <label class="form-label">Vehiculo</label>
                <div class="d-flex flex-row">
                    <div class="form-check"
                            style="display: flex; align-content: center; align-items: center; justify-content: center; gap: 30px;">
                        <input class="form-check-input" type="radio" name="radioDefault" id="Interno" checked>
                        <label class="form-check-label" for="Interno" style="margin-bottom:-5px;">Propio</label>
                    </div>
                    <div class="form-check"
                            style="display: flex; align-content: center; align-items: center; justify-content: center; gap: 30px;">
                        <input class="form-check-input" type="radio" name="radioDefault" id="Externo">
                        <label class="form-check-label" for="Externo" style="margin-bottom:-5px;">Externo</label>
                    </div>
                </div>
              </div>
              <div class="col-md-4">
                <label class="form-label">Tipo de Servicio</label>
                <select id="TipoServicio" class="form-select"></select>
              </div>
              <div class="col-md-4">
                <label class="form-label">Categoria de Vehiculo</label>
                <Select id="CategoriaVehiculo" class="form-select"></Select>
              </div>
              <div class="col-md-4">
                <label class="form-label">Tipo Vehículo</label>
                <select id="TipoVehiculo" class="form-select"></select>
              </div>
              <div class="col-md-4">
                <label class="form-label">Marca</label>
                <input id="Marca" class="form-control text-uppercase" />
              </div>
              <div class="col-md-4">
                <label class="form-label">Linea</label>
                <input id="Linea" class="form-control text-uppercase" />
              </div>
              <div class="col-md-4">
                <label class="form-label">Modelo</label>
                <input id="Modelo" class="form-control text-uppercase" />
              </div>
              <div class="col-md-4">
                <label class="form-label">Color</label>
                <input id="Color" class="form-control text-uppercase" />
              </div>
              <div class="col-md-8">
                <label class="form-label">Observaciones</label>
                <textarea id="Observaciones" class="form-control"> </textarea>
              </div>
            </div>
          </div>
          <div class="tab-pane fade" id="propietario" role="tabpanel" aria-labelledby="propietario-tab" tabindex="0">
            <div class="row gy-2">
              <h6 class="fw-semibold small text-uppercase text-muted mb-2">Propietario</h6>
              <div class="col-md-4">
                <label class="form-label">Nombre del propietario</label>
                <input id="NombrePropietario" class="form-control" />
              </div>
              <div class="col-md-4">
                <label class="form-label">Cedula del propietario</label>
                <input type="number" id="CedulaPropietario" class="form-control" />
              </div>
              <div class="col-md-4">
                <label class="form-label">Telefono del propietario</label>
                <input type="number" id="TelefonoPropietario" class="form-control" />
              </div>
            </div>
          </div>
          <div class="tab-pane fade" id="motorCaracteristicas" role="tabpanel"
               aria-labelledby="motorCaracteristicas-tab" tabindex="0">
            <div class="row">
              <div class="col-sm-12 row gy-2">
                <h6 class="fw-semibold small text-uppercase text-muted mb-2">Motor</h6>
                <div class="col-md-6">
                  <label class="form-label">Numero de serie</label>
                  <input id="NumeroSerie" class="form-control text-uppercase" />
                </div>
                <div class="col-md-6">
                  <label class="form-label">Numero de motor</label>
                  <input id="NumeroMotor" class="form-control text-uppercase" />
                </div>
                <div class="col-md-6">
                  <label class="form-label">Numero de chasis</label>
                  <input id="NumeroChasis" class="form-control text-uppercase" />
                </div>
                <div class="col-md-6">
                  <label class="form-label">Numero VIN</label>
                  <input id="NumeroVIN" class="form-control text-uppercase" />
                </div>
                <div class="col-md-3">
                  <label class="form-label">Cilindraje</label>
                  <input type="number" id="Cilindraje" class="form-control text-uppercase" />
                </div>
                <div class="col-md-4">
                  <label class="form-label">Tipo de Combustible</label>
                  <input id="TipoCombustible" class="form-control text-uppercase" />
                </div>
              </div>
              <div class="col-sm-12 row gy-2">
                <h6 class="fw-semibold small text-uppercase text-muted mb-2">Caracteristicas Tecnicas</h6>
                <div class="col-md-4">
                  <label class="form-label">Tipo de carroceria</label>
                  <input id="TipoCarroceria" class="form-control text-uppercase" />
                </div>
                <div class="col-md-2">
                  <label class="form-label">Pasajeros</label>
                  <input type="number" id="CapacidadPasajeros" class="form-control" />
                </div>
                <div class="col-md-2">
                  <label class="form-label">Pasajeros sentados</label>
                  <input type="number" id="CapacidadPasajerosSentados" class="form-control" />
                </div>
                <div class="col-md-2">
                  <label class="form-label">Capacidad de carga</label>
                  <input type="number" id="CapacidadCarga" class="form-control" />
                </div>
                <div class="col-md-2">
                  <label class="form-label">Peso bruto vehicular</label>
                  <input type="number" id="PesoBrutoVehicular" class="form-control" />
                </div>
                <div class="col-md-2">
                  <label class="form-label">Numero de ejes</label>
                  <input type="number" id="NumeroEjes" class="form-control" />
                </div>
                <div class="col-md-2">
                  <label class="form-label">Puertas</label>
                  <input type="number" id="Puertas" class="form-control" />
                </div>
              </div>
            </div>
          </div>
          <div class="tab-pane fade" id="matricula" role="tabpanel" aria-labelledby="matricula-tab" tabindex="0">
            <div class="row gy-2">
              <h6 class="fw-semibold small text-uppercase text-muted mb-2">Matricula</h6>
              <div class="col-md-3">
                <label class="form-label">Matricula inicial</label>
                <input type="date" id="FechaMatriculaInicial" class="form-control" />
              </div>
              <div class="col-md-6">
                <label class="form-label">Autoridad de transito</label>
                <input id="AutoridadTransito" class="form-control" />
              </div>
            </div>
          </div>
          <div class="tab-pane fade" id="documentos" role="tabpanel" aria-labelledby="Documentos-tab" tabindex="0">
            <div class="row">
              <div class="col-sm-12 row gy-2">
                <h6 class="fw-semibold small text-uppercase text-muted mb-2">
                SOAT <span id="SoatEstadoBadge" class="badge rounded-pill text-bg-secondary ms-2 align-self-center d-none"> Sin calcular</span>
                </h6>
                <div class="col-md-4">
                  <label class="form-label">Numero de poliza</label>
                  <input id="SoatNumeroPoliza" class="form-control" />
                </div>
                <div class="col-md-4">
                  <label class="form-label">Entidad que expide</label>
                  <input id="SoatEntidadExpide" class="form-control" />
                </div>
                <div class="col-md-4">
                  <label class="form-label">Estado</label>
                  <select id="SoatEstado" class="form-select"></select>
                </div>
                <div class="col-md-3">
                  <label class="form-label">Expedicion</label>
                  <input type="date" id="SoatFechaExpedicion" class="form-control" />
                </div>
                <div class="col-md-3">
                  <label class="form-label">Inicio de vigencia</label>
                  <input type="date" id="SoatFechaInicioVigencia" class="form-control" />
                </div>
                <div class="col-md-3">
                  <label class="form-label">Fin de vigencia</label>
                  <input type="date" id="SoatFechaFinVigencia" class="form-control" />
                </div>
                <div class="col-md-3">
                    <label class="form-label">vigente (dias)</label>
                  <input id="SoatVigente" class="form-control" />
                </div>
                <div class="col-md-6">
                  <label class="form-label">Documento PDF</label>
                  <input type="file" id="documentoSoat" class="form-control" />
                </div>
              </div>
              <div class="col-sm-12 row gy-2">
                <h6 class="fw-semibold small text-uppercase text-muted mb-2">
                Poliza <span id="PolizaEstadoBadge" class="badge rounded-pill text-bg-secondary ms-2 align-self-center d-none"> Sin calcular</span>
                </h6>
                <div class="col-md-3">
                  <label class="form-label">Numero de poliza</label>
                  <input id="PolizaNumero" class="form-control" />
                </div>
                <div class="col-md-3">
                  <label class="form-label">Tipo de poliza</label>
                  <input id="PolizaTipo" class="form-control" />
                </div>
                <div class="col-md-3">
                  <label class="form-label">Entidad que expide</label>
                  <input id="PolizaEntidadExpide" class="form-control" />
                </div>
                <div class="col-md-3">
                  <label class="form-label">Estado</label>
                  <Select id="PolizaEstado" class="form-select"> </Select>
                </div>
                <div class="col-md-3">
                  <label class="form-label">Expedicion</label>
                  <input type="Date" id="PolizaFechaExpedicion" class="form-control" />
                </div>
                <div class="col-md-3">
                  <label class="form-label">Inicio de vigencia</label>
                  <input type="Date" id="PolizaFechaInicioVigencia" class="form-control" />
                </div>
                <div class="col-md-3">
                  <label class="form-label">Fin de vigencia</label>
                  <input type="Date" id="PolizaFechaFinVigencia" class="form-control" />
                </div>
                <div class="col-md-3">
                 <label class="form-label">Vigente (dias)</label>
                  <input id="PolizaVigente" class="form-control" />
                </div>
                <div class="col-md-6">
                  <label class="form-label">Documento PDF</label>
                  <input type="file" id="documentoPoliza" class="form-control" />
                </div>
              </div>
              <div class="col-sm-12 row gy-2">
                <h6 class="fw-semibold small text-uppercase text-muted mb-2">
                Revisión Tecnico-Mecanica <span id="RTMEstadoBadge" class="badge rounded-pill text-bg-secondary ms-2 align-self-center d-none"> Sin calcular</span>
                </h6>
                <div class="col-md-3">
                  <label class="form-label">Tipo de revision</label>
                  <input id="RtmTipoRevision" class="form-control" />
                </div>
                <div class="col-md-3">
                  <label class="form-label">Numero de certificado</label>
                  <input id="RtmNumeroCertificado" class="form-control" />
                </div>
                <div class="col-md-3">
                  <label class="form-label">CDA que expide</label>
                  <input id="RtmCDAExpide" class="form-control" />
                </div>
                <div class="col-md-3">
                  <label class="form-label">Estado</label>
                  <select id="RtmEstado" class="form-select"> </select>
                </div>
                <div class="col-md-3">
                  <label class="form-label">Expedicion</label>
                  <input type="Date" id="RtmFechaExpedicion" class="form-control" />
                </div>
                <div class="col-md-3">
                  <label class="form-label">Inicio de vigencia</label>
                  <input type="Date" id="RtmFechaInicioVigencia" class="form-control" />
                </div>
                <div class="col-md-3">
                  <label class="form-label">Fin de vigencia</label>
                  <input type="Date" id="RtmFechaFinVigencia" class="form-control" />
                </div>
                <div class="col-md-3">
                  <label class="form-label">Vigencia (dias)</label>
                  <input id="RtmVigente" class="form-control" />
                </div>
                <div class="col-md-6">
                  <label class="form-label">Documento PDF</label>
                  <input type="file" id="documentoRTM" class="form-control" />
                </div>
              </div>
              <div class="col-sm-12 row gy-2 mb-3">
                <h6 class="fw-semibold small text-uppercase text-muted mb-2">
                Tarjeta de Operación <span id="TOEstadoBadge" class="badge rounded-pill text-bg-secondary ms-2 align-self-center d-none"> Sin calcular</span>
                </h6>
                <div class="col-md-4">
                  <label class="form-label">Empresa afiliadora</label>
                  <input id="EmpresaAfiliadora" class="form-control" />
                </div>
                <div class="col-md-4">
                  <label class="form-label">Tarjeta de operacion</label>
                  <input id="NumeroTarjetaOperacion" class="form-control" />
                </div>
                <div class="col-md-4">
                    <label class="form-label">Estado</label>
                    <select id="EstadoTarjetaOperacion" class="form-select"> </select>
                </div>
                <div class="col-md-3">
                  <label class="form-label">Expedicion</label>
                  <input type="Date" id="FechaExpedicionTarjeta" class="form-control" />
                </div>
                <div class="col-md-3">
                  <label class="form-label">Inicio de vigencia</label>
                  <input type="Date" id="FechaInicioVigenciaTarjeta" class="form-control" />
                </div>
                <div class="col-md-3">
                  <label class="form-label">Fin de vigencia</label>
                  <input type="Date" id="FechaFinVigenciaTarjeta" class="form-control" />
                </div>
                <div class="col-md-3">
                  <label class="form-label">Vigente (dias)</label>
                  <input type="text" id="TarjetaOperacionVigente" class="form-control" />
                </div>
              </div>
            </div>
          </div>
          <div class="tab-pane fade" id="configuracion" role="tabpanel" aria-labelledby="configuracion-tab"
               tabindex="0">
            <div class="row">
              <div class="col-sm-12 row gy-2">
                <h6 class="fw-semibold small text-uppercase text-muted mb-2">Blindaje</h6>
                <div class="col-md-3">
                  <label class="form-label">Blindado</label>
                  <input type="checkbox" id="Blindado">
                </div>
              </div>
              <div class="col-sm-12 row gy-2">
                <h6 class="fw-semibold small text-uppercase text-muted mb-2">Regrabación</h6>
                <div class="col-md-6">
                  <label class="form-label">Nro. de regrabacion de motor</label>
                  <input id="RegrabacionMotor" class="form-control" />
                </div>
                <div class="col-md-6">
                  <label class="form-label">Nro. de regrabacion de chasis</label>
                  <input id="RegrabacionChasis" class="form-control" />
                </div>
                <div class="col-md-6">
                  <label class="form-label">Nro. de serie de regrabacion</label>
                  <input id="RegrabacionSerie" class="form-control" />
                </div>
                <div class="col-md-6">
                  <label class="form-label">Nro. de regrabacion VIN</label>
                  <input id="RegrabacionVIN" class="form-control" />
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
  <div class="col-lg-4">
    <div class="card border-0 shadow-sm rounded-4">
      <div class="card-body p-4">
        <h6 class="fw-semibold mb-3"><i class="bi bi-info-circle me-2 text-primary"></i>Documentos requeridos</h6>
        @foreach (var (icon, doc, desc) in new[] {
          ("bi-file-earmark-check", "SOAT", "Seguro Obligatorio de Accidentes de Tránsito"),
          ("bi-wrench-adjustable", "Revisión Técnico-Mecánica", "Certificado de revisión periódica obligatoria"),
          ("bi-shield-shaded", "Seguro del Vehículo", "Póliza de seguro todo riesgo o responsabilidad civil")
        })
        {
          <div class="d-flex gap-3 mb-3">
            <div class="rounded-3 d-flex align-items-center justify-content-center flex-shrink-0"
                 style="width:34px;height:34px;background:#dbeafe;font-size:16px;color:#1d4ed8;">
              <i class="bi @icon"></i>
            </div>
            <div>
              <div class="fw-semibold small">@doc</div>
              <div class="text-muted" style="font-size:12px;">@desc</div>
            </div>
          </div>
        }
        <div class="alert alert-warning rounded-3 small py-2 mt-2 mb-0">
          <i class="bi bi-exclamation-triangle me-1"></i>
          El sistema alertará 30 días antes del vencimiento de cada documento.
        </div>
      </div>
    </div>
  </div>
</div>
@section Scripts {
  <partial name="_ValidationScriptsPartial" />
  <script>

    $(document).ready(function () {
        cargarListados();
        calcularDiasVigencia('#SoatFechaInicioVigencia','#SoatFechaFinVigencia','#SoatVigente');
        calcularDiasVigencia('#PolizaFechaInicioVigencia','#PolizaFechaFinVigencia','#PolizaVigente');
        calcularDiasVigencia('#RtmFechaExpedicion','#RtmFechaVigencia','#RtmVigente');
        calcularDiasVigencia('#FechaInicioVigenciaTarjeta','#FechaFinVigenciaTarjeta','#TarjetaOperacionVigente');
    });
    $("#TipoServicio").on("change",function (){
        select = parseInt($(this).val());
        switch (select) {
          case 1:
                $("#placaPreview").css("background", "#f8d117");
            break;
          case 2:
                $("#placaPreview").css("background", "#FFF");
            break;
          case 3:
                $("#placaPreview").css("background", "#FFF");
            break;
          case 4:
                $("#placaPreview").css("background", "#FFF");
            break;
          default:
                $("#placaPreview").css("background", "#f8d117");
            break;
        }
        if(select = 1){
            
        }
    })

    $("#Placa").on("keyup change", function () {

      let placa = $(this).val().toUpperCase();
      placa = placa.replace(/[^A-Z0-9]/g, '');

      if (placa.length >= 6) {
        let letras = placa.substring(0, 3);
        let numeros = placa.substring(3);

        placa = letras + "-" + numeros;
      }

      $("#placaPreview").text(placa || "ABC-123");

    });
           
    $('#SoatFechaInicioVigencia, #SoatFechaFinVigencia').on('change', function () {
        calcularDiasVigencia('#SoatFechaInicioVigencia','#SoatFechaFinVigencia','#SoatVigente');
        actualizarBadgeVigencia('#SoatVigente','#SoatEstadoBadge');
    });

    $('#PolizaFechaInicioVigencia, #PolizaFechaFinVigencia').on('change', function () {
        calcularDiasVigencia('#PolizaFechaInicioVigencia','#PolizaFechaFinVigencia','#PolizaVigente');
        actualizarBadgeVigencia('#PolizaVigente','#PolizaEstadoBadge');
    });

    $('#RtmFechaInicioVigencia, #RtmFechaFinVigencia').on('change', function () {
        calcularDiasVigencia('#RtmFechaInicioVigencia','#RtmFechaFinVigencia','#RtmVigente');
        actualizarBadgeVigencia('#RtmVigente','#RTMEstadoBadge');
    });

