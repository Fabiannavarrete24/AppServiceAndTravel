    $("#btnGuardar").click(function () {

      const model = obtenerModel();
      $.ajax({
        url: '/Operaciones/Vehiculos/GuardarVehiculo',
        type: 'POST',
        data: model,
        beforeSend: function () {
          showLoader();
        },
        success: function (response) {
          toastr.success(response);
        },
        complete: function () {
          toastr.error("Error guardando vehículo");
          hideLoader();
        },
        error: function (error) {
          showToast($`Error cargando vehículo: ${error}`,"danger");
        }
      });

    });

    $("#btnDeshabilitar").click(async function () {

      let id = $("#idVehiculo").val();

      if (!id || id == 0)
        return;

      if (!confirm("¿Desea deshabilitar este vehículo?"))
        return;

      const response = await $.post(
        '/Operaciones/Vehiculos/Deshabilitar',
        { id }
      );

      if (response.success) {
         showToast($`${response.message}`,"success");

        limpiarFormulario();

      }

    });

    $("#txtBuscarVehiculo").autocomplete({

      minLength: 2,

      source: function (request, response) {

        $.get("/Operaciones/Vehiculos/BuscarVehiculo",
          {
            term: request.term
          },
          function (data) {
            response(data);
          });

      },

      select: function (event, ui) {

        if (ui.item.id) {

          cargarVehiculo(ui.item.id);

        }

      }

    });

    function cargarListados() {

      try {

        $.ajax({
            url: '/Helps/ObtenerListadoSelect',
            type: 'GET',
            beforeSend: function () {
                showLoader();
            },
            success: function(response){
                LoadSelect("#TipoServicio", response.data.tiposServicio);
                LoadSelect("#Estado", response.data.estados);
                LoadSelect("#SoatEstado", response.data.estados);
                LoadSelect("#PolizaEstado", response.data.estados);
                LoadSelect("#RtmEstado", response.data.estados);
                LoadSelect("#EstadoTarjetaOperacion", response.data.estados);
                LoadSelect("#TipoServicio", response.data.tiposServicio);
                LoadSelect("#TipoVehiculo", response.data.tiposVehiculo);
                LoadSelect("#CategoriaVehiculo",response.data.categoriasVehiculo);
            },
            complete: function () {
                hideLoader();
            }
        });
          
      }
      catch (e) {

        console.error(e);

      }

    }

    $("#CategoriaVehiculo").on("change", function () {

        let idCategoria = $(this).val();

        $("#TipoVehiculo").empty();

        if (!idCategoria)
            return;

        $.ajax({
            url: '/Helps/ObtenerTiposVehiculo',
            type: 'GET',
            beforeSend: function () {
                showLoader();
            },
            data: {
                  idCategoria: idCategoria
            },
            success: function (data) {
                LoadSelect("#TipoVehiculo",data);
            },
            complete: function () {
                hideLoader();
            }
        });

    });

