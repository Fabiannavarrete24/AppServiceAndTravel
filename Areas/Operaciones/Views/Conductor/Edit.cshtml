@model AppServiceAndTravel.Models.Conductor

@{
    ViewData["Title"] = "Editar Conductor";
}
<form asp-action="Edit" method="post">

    <input type="hidden" asp-for="idConductor" />

    @Html.AntiForgeryToken()

    <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

    <div class="row g-3">

        <div class="col-md-6">
            <label asp-for="NombreCompleto" class="form-label"></label>
            <input asp-for="NombreCompleto" class="form-control" />
            <span asp-validation-for="NombreCompleto" class="text-danger"></span>
        </div>

        <div class="col-md-6">
            <label asp-for="Cedula" class="form-label"></label>
            <input asp-for="Cedula" class="form-control" />
            <span asp-validation-for="Cedula" class="text-danger"></span>
        </div>

        <div class="col-md-6">
            <label asp-for="Telefono" class="form-label"></label>
            <input asp-for="Telefono" class="form-control" />
        </div>

        <div class="col-md-6">
            <label asp-for="correo" class="form-label"></label>
            <input asp-for="correo" class="form-control" />
        </div>

        <div class="col-md-6">
            <label asp-for="NumeroLicencia" class="form-label"></label>
            <input asp-for="NumeroLicencia" class="form-control" />
        </div>

        <div class="col-md-6">
            <label asp-for="FechaVencimientoLicencia" class="form-label"></label>
            <input asp-for="FechaVencimientoLicencia"
                   type="date"
                   class="form-control" />
        </div>

        <div class="col-md-6">
            <label asp-for="TipoProveedor" class="form-label"></label>
            <select asp-for="TipoProveedor"
                    asp-items="Html.GetEnumSelectList<TipoProveedor>()"
                    class="form-select">
            </select>
        </div>

        <div class="col-md-6 d-flex align-items-center">
            <div class="form-check mt-4">
                <input asp-for="Activo" class="form-check-input" />
                <label asp-for="Activo" class="form-check-label"></label>
            </div>
        </div>

    </div>

    <div class="mt-4 d-flex gap-2">
        <button class="btn btn-primary">
            <i class="bi bi-save me-1"></i>Guardar
        </button>

        <a asp-action="Index" class="btn btn-outline-secondary">
            Cancelar
        </a>
    </div>

</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}