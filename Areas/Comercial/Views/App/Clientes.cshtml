@{ ViewData["Title"] = "Clientes"; }

<div class="row g-3 mb-4">
    @foreach(var (lbl,val,bg,color,icon) in new[]{
        ("Total clientes",    (int)ViewBag.Total,    "#dbeafe","#1d4ed8","bi-people"),
        ("Activos",           (int)ViewBag.Activos,  "#d1fae5","#065f46","bi-check-circle"),
        ("Inactivos",         (int)ViewBag.Inactivos,"#fee2e2","#991b1b","bi-x-circle"),
    })
    {
    <div class="col-sm-4">
        <div class="card">
            <div class="card-body d-flex align-items-center gap-3 p-3">
                <div class="rounded-3 d-flex align-items-center justify-content-center"
                     style="width:44px;height:44px;background:@bg;color:@color;font-size:20px;flex-shrink:0;">
                    <i class="bi @icon"></i>
                </div>
                <div>
                    <div class="text-muted" style="font-size:12px;">@lbl</div>
                    <div class="fw-bold fs-4" style="color:@color;">@val</div>
                </div>
            </div>
        </div>
    </div>
    }
</div>
<div class="card">
    <div class="card-header bg-white py-3 px-4 d-flex flex-wrap align-items-center gap-3">
        <span class="fw-semibold flex-grow-1">Directorio de clientes</span>
        <form method="get" class="d-flex gap-2">
            <input type="search" name="q" value="Q" class="form-control form-control-sm rounded-3"
                   placeholder="Buscar…" style="min-width:180px;" />
            <div class="form-check form-switch ms-2 d-flex align-items-center mb-0">
                <input class="form-check-input" type="checkbox" name="soloActivos" value="true"
                       id="chkActivos" checked
                       onchange="this.form.submit()" />
                <label class="form-check-label small ms-2" for="chkActivos">Solo activos</label>
            </div>
            <button class="btn btn-sm btn-outline-primary rounded-3"><i class="bi bi-search"></i></button>
        </form>
        <a asp-area="Comercial" asp-controller="Cliente" asp-action="Create"
           class="btn btn-primary btn-sm rounded-3">
            <i class="bi bi-person-plus me-1"></i>Nuevo cliente
        </a>
    </div>
    <div class="card-body p-0">
        <div class="text-center py-5 text-muted">
            <i class="bi bi-people" style="font-size:42px;opacity:.25;"></i>
            <p class="mt-2">No hay clientes registrados.</p>
        </div>
        <div class="table-responsive">
            <table class="table table-hover mb-0 align-middle">
                <thead>
                    <tr>
                        <th class="ps-4">Cliente</th>
                        <th>NIT / Cédula</th>
                        <th>Contacto</th>
                        <th>Ciudad</th>
                        <th>Cotizaciones</th>
                        <th>Estado</th>
                        <th class="text-end pe-4">Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <td class="ps-4">
                            <div class="d-flex align-items-center gap-3">
                                <div class="rounded-circle fw-bold d-flex align-items-center justify-content-center"
                                     style="width:38px;height:38px;background:var(--cp);color:#fff;font-size:15px;flex-shrink:0;">
                                    NombreCompleto
                                </div>
                                <div>
                                    <div class="fw-semibold small">NombreCompleto</div>
                                    <div class="text-muted" style="font-size:12px;">Desde FechaCreacion.ToString("dd/MM/yyyy")</div>
                                </div>
                            </div>
                        </td>
                        <td class="small">NitCedula</td>
                        <td>
                            <div class="small"></div>
                            <div class="text-muted" style="font-size:12px;"><i class="bi bi-telephone me-1"></i>Telefono</div>
                        </td>
                        <td class="small text-muted">Ciudad</td>
                        <td>
                            <span class="badge rounded-pill px-3 py-2" style="background:#dbeafe;color:#1e40af;">
                                Cotizaciones
                            </span>
                        </td>
                        <td>
                            <span class="badge rounded-pill px-3 py-2"
                                  style="background:#d1fae5;color:#065f46;">
                            </span>
                        </td>
                        <td class="text-end pe-4">
                            <div class="d-flex justify-content-end gap-1">
                                <a asp-area="Comercial" asp-controller="Cliente" asp-action="Details" asp-route-id="idCliente"
                                   class="btn btn-sm btn-outline-secondary rounded-3" title="Ver"><i class="bi bi-eye"></i></a>
                                <a asp-area="Comercial" asp-controller="Cliente" asp-action="Edit" asp-route-id="idCliente"
                                   class="btn btn-sm btn-outline-primary rounded-3" title="Editar"><i class="bi bi-pencil"></i></a>
                                <form asp-area="Comercial" asp-controller="Cliente" asp-action="ToggleActivo" asp-route-id="idCliente" method="post">
                                    <button type="submit" class="btn btn-sm rounded-3"
                                            style="border:1px solid #f59e0b;color:#92400e;"
                                            title="Desactivar">
                                        <i class="bi bi-person-dash"></i>
                                    </button>
                                </form>
                            </div>
                        </td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>
    <!-- modal Editar Usuarios -->
    <div class="modal fade" id="exampleModal" tabindex="-1" aria-labelledby="exampleModalLabel" aria-hidden="true">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <div class="rounded-3 d-flex align-items-center justify-content-center" style="width:36px;height:36px;background:#dbeafe;font-size:18px;color:#1d4ed8;">
                        <i class="fa-solid fa-user-plus"></i>
                    </div>
                    <div>
                        <h5 class="mb-0 fw-semibold">Nuevo usuario</h5>
                        <small class="text-muted">Complete los datos de acceso y asigne el rol correspondiente</small>
                    </div>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <form id="formCreateUser">
                        <h6 class="fw-semibold small text-uppercase text-muted mb-3">Datos personales</h6>
                        <div class="row gy-3 mb-4">
                            <div class="col-sm-4">
                                <label class="form-label fw-semibold small">UserName</label>
                                <input class="form-control rounded-3" required disabled />
                                <span class="text-danger small"></span>
                            </div>
                            <div class="col-sm-4">
                                <label class="form-label fw-semibold small">Nombre completo *</label>
                                <input class="form-control rounded-3" required />
                                <span class="text-danger small"></span>
                            </div>
                            <div class="col-sm-4">
                                <label class="form-label fw-semibold small">Cargo</label>
                                <input class="form-control rounded-3" placeholder="Ej: Coordinador operativo" />
                            </div>
                            <div class="col-sm-4">
                                <label class="form-label fw-semibold small">Teléfono</label>
                                <input class="form-control rounded-3" />
                            </div>
                            <div class="col-sm-4">
                                <label class="form-label fw-semibold small">Email *</label>
                                <input type="email" class="form-control rounded-3" required />
                                <span lass="text-danger small"></span>
                            </div>
                            <div class="col-sm-4">
                                <label class="form-label">Contraseña *</label>
                                <div class="input-group">
                                    <input type="password" class="form-control" id="pwUser">
                                    <button type="button" class="btn btn-outline-secondary" onclick="togglePwd('pwUser','icoPW')">
                                        <i class="fa-solid fa-eye" id="icoPW"></i>
                                    </button>
                                </div>
                            </div>
                            <div class="col-sm-5">
                                <label class="form-label">Roles y Permisos</label>
                                <select id="selectRol" class="form-select">
                                </select>
                            </div>
                        </div>
                        <div class="d-flex gap-3 pt-2">
                            <button type="submit" class="btn btn-primary px-4 rounded-3">
                                <i class="fa-solid fa-user-plus me-2"></i>Crear usuario
                            </button>
                            <a class="btn btn-outline-secondary rounded-3">Cancelar</a>
                        </div>
                    </form>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
                    <button type="button" class="btn btn-primary">Save changes</button>
                </div>
            </div>
        </div>
    </div>
</div>
