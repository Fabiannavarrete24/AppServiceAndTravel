@* @model AppServiceAndTravel.Models.Cotizacion
@{
    ViewData["Title"] = "Nueva Cotización";
    ViewData["Breadcrumb"] = "Cotizaciones / Nueva";
}
 *@
<div class="row g-4">
  <div class="col-lg-8">
    <div class="card border-0 shadow-sm rounded-4">
      <div class="card-header bg-white border-0 pt-4 px-4 pb-0 d-flex align-items-center gap-2">
        <div class="rounded-3 d-flex align-items-center justify-content-center"
             style="width:36px;height:36px;background:#dbeafe;">
          <i class="bi bi-file-earmark-plus text-primary fs-5"></i>
        </div>
        <div>
          <h5 class="mb-0 fw-semibold">Datos de la cotización</h5>
          <small class="text-muted">Complete todos los campos requeridos</small>
        </div>
      </div>
      <div class="card-body px-4 pb-4 pt-3">
        <form asp-action="Create" method="post" id="formCotizacion">
          @* @Html.AntiForgeryToken() *@
          <div asp-validation-summary="ModelOnly" class="alert alert-danger rounded-3 py-2 small"></div>

          <!-- Cliente -->
          <div class="mb-4">
            <label  class="form-label fw-semibold small text-uppercase text-secondary ls-1">
              Cliente <span class="text-danger">*</span>
            </label>
            <select asp-items="ViewBag.Clientes" class="form-select rounded-3" required>
              <option value="">— Seleccione un cliente —</option>
            </select>
            <span class="text-danger small"></span>
          </div>

          <!-- Origen / Destino -->
          <div class="row g-3 mb-4">
            <div class="col-md-6">
              <label  class="form-label fw-semibold small text-uppercase text-secondary">
                Origen <span class="text-danger">*</span>
              </label>
              <div class="input-group">
                <span class="input-group-text bg-light border-end-0">
                  <i class="bi bi-geo-alt text-muted"></i>
                </span>
                <input class="form-control border-start-0 rounded-end-3"
                       placeholder="Ciudad / dirección de origen" required />
              </div>
              <span class="text-danger small"></span>
            </div>
            <div class="col-md-6">
              <label  class="form-label fw-semibold small text-uppercase text-secondary">
                Destino <span class="text-danger">*</span>
              </label>
              <div class="input-group">
                <span class="input-group-text bg-light border-end-0">
                  <i class="bi bi-geo-alt-fill text-primary"></i>
                </span>
                <input class="form-control border-start-0 rounded-end-3"
                       placeholder="Ciudad / dirección de destino" required />
              </div>
              <span class="text-danger small"></span>
            </div>
          </div>

          <!-- Fecha + Pasajeros -->
          <div class="row g-3 mb-4">
            <div class="col-md-6">
              <label class="form-label fw-semibold small text-uppercase text-secondary">
                Fecha del servicio <span class="text-danger">*</span>
              </label>
              <div class="input-group">
                <span class="input-group-text bg-light border-end-0">
                  <i class="bi bi-calendar3 text-muted"></i>
                </span>
                <input type="date" class="form-control border-start-0 rounded-end-3"
                       min="@DateTime.Today.ToString("yyyy-MM-dd")" required />
              </div>
              <span  class="text-danger small"></span>
            </div>
            <div class="col-md-6">
              <label class="form-label fw-semibold small text-uppercase text-secondary">
                N° de pasajeros
              </label>
              <div class="input-group">
                <span class="input-group-text bg-light border-end-0">
                  <i class="bi bi-people text-muted"></i>
                </span>
                <input  type="number" class="form-control border-start-0 rounded-end-3"
                       min="0" max="99" value="0" />
              </div>
            </div>
          </div>

          <!-- Valor -->
          <div class="mb-4">
            <label  class="form-label fw-semibold small text-uppercase text-secondary">
              Valor cotizado (COP) <span class="text-danger">*</span>
            </label>
            <div class="input-group">
              <span class="input-group-text bg-light border-end-0 fw-semibold">$</span>
              <input  type="number" class="form-control border-start-0"
                     step="1000" min="0" placeholder="0" required />
              <span class="input-group-text bg-light border-start-0 rounded-end-3">COP</span>
            </div>
            <span  class="text-danger small"></span>
          </div>

          <!-- Descripción carga -->
          <div class="mb-4">
            <label class="form-label fw-semibold small text-uppercase text-secondary">
              Descripción de la carga / servicio
            </label>
            <textarea class="form-control rounded-3" rows="3"
                      placeholder="Detalle del tipo de carga, condiciones especiales, requisitos del servicio…"></textarea>
          </div>

          <div class="d-flex gap-3 pt-2">
            <button type="submit" class="btn btn-primary px-4 rounded-3">
              <i class="bi bi-send me-2"></i>Crear cotización
            </button>
            <a asp-action="Index" class="btn btn-outline-secondary rounded-3">Cancelar</a>
          </div>
        </form>
      </div>
    </div>
  </div>

  <!-- Sidebar info -->
  <div class="col-lg-4">
    <div class="card border-0 shadow-sm rounded-4 mb-3">
      <div class="card-body p-4">
        <h6 class="fw-semibold mb-3"><i class="bi bi-info-circle me-2 text-primary"></i>¿Qué sucede al crear?</h6>
        <div class="d-flex gap-3 mb-3">
          <div class="rounded-circle d-flex align-items-center justify-content-center flex-shrink-0"
               style="width:32px;height:32px;background:#dbeafe;font-size:14px;color:#1d4ed8;">1</div>
          <div>
            <div class="fw-semibold small">Cotización en estado Pendiente</div>
            <div class="text-muted" style="font-size:12px;">Queda lista para revisión del aprobador.</div>
          </div>
        </div>
        <div class="d-flex gap-3 mb-3">
          <div class="rounded-circle d-flex align-items-center justify-content-center flex-shrink-0"
               style="width:32px;height:32px;background:#d1fae5;font-size:14px;color:#065f46;">2</div>
          <div>
            <div class="fw-semibold small">Notificación al cliente</div>
            <div class="text-muted" style="font-size:12px;">Se envía correo de confirmadaación automáticamente.</div>
          </div>
        </div>
        <div class="d-flex gap-3">
          <div class="rounded-circle d-flex align-items-center justify-content-center flex-shrink-0"
               style="width:32px;height:32px;background:#ede9fe;font-size:14px;color:#6d28d9;">3</div>
          <div>
            <div class="fw-semibold small">Revisión y aprobación</div>
            <div class="text-muted" style="font-size:12px;">El aprobador puede aceptar, modificar el valor o rechazar.</div>
          </div>
        </div>
      </div>
    </div>

    <div class="card border-0 shadow-sm rounded-4">
      <div class="card-body p-4">
        <h6 class="fw-semibold mb-3"><i class="bi bi-person-plus me-2 text-primary"></i>¿Cliente nuevo?</h6>
        <p class="text-muted small mb-3">Si el cliente no aparece en la lista, regístrelo primero.</p>
        <a asp-controller="Cliente" asp-action="Create" class="btn btn-outline-primary btn-sm rounded-3 w-100">
          <i class="bi bi-plus-lg me-1"></i>Registrar cliente
        </a>
      </div>
    </div>
  </div>
</div>

@section Scripts {
<partial name="_ValidationScriptsPartial" />
<script>
  // Preview del valor formateado
  document.querySelector('input[name="ValorCotizado"]').addEventListener('input', function() {
    var v = parseFloat(this.value) || 0;
    var fmt = new Intl.NumberFormat('es-CO', { style: 'currency', currency: 'COP', maximumFractionDigits: 0 }).format(v);
    document.getElementById('valorPreview').textContent = fmt;
  });
</script>
}
