@{
    ViewData["Title"] = "Dashboard";
}
<div class="row g-3 mb-4">
    <div class="col-sm-6 col-xl-3">
        <div class="card h-100">
            <div class="card-body d-flex align-items-center gap-3">
                <div class="rounded-circle d-flex align-items-center justify-content-center"
                     style="width:48px;height:48px;background:#fef3c7;color:#92400e;font-size:22px;">
                    <i class="fa-solid fa-clock"></i>
                </div>
                <div>
                    <div class="text-muted" style="font-size:16px;">Pendientes</div>
                    <div id="totalPendientes" style="font-size:24px;font-weight:700;">
                        0
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-xl-3">
        <div class="card h-100">
            <div class="card-body d-flex align-items-center gap-3">
                <div class="rounded-circle d-flex align-items-center justify-content-center"
                     style="width:48px;height:48px;background:#d1fae5;color:#065f46;font-size:22px;">
                    <i class="fa-solid fa-circle-check"></i>
                </div>
                <div>
                    <div class="text-muted" style="font-size:16px;">Aprobadas</div>
                    <div id="totalAprobadas" style="font-size:24px;font-weight:700;">0</div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-xl-3">
        <div class="card h-100">
            <div class="card-body d-flex align-items-center gap-3">
                <div class="rounded-circle d-flex align-items-center justify-content-center"
                     style="width:48px;height:48px;background:#fee2e2;color:#991b1b;font-size:22px;">
                    <i class="fa-solid fa-circle-xmark"></i>
                </div>
                <div>
                    <div class="text-muted" style="font-size:16px;">Rechazadas</div>
                    <div id="totalRechazadas" style="font-size:24px;font-weight:700;">0</div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-xl-3">
        <div class="card h-100">
            <div class="card-body d-flex align-items-center gap-3">
                <div class="rounded-circle d-flex align-items-center justify-content-center"
                     style="width:48px;height:48px;background:#dbeafe;color:#1e40af;font-size:22px;">
                    <i class="fa-solid fa-file"></i>
                </div>
                <div>
                    <div class="text-muted" style="font-size:16px;">Total</div>
                    <div id="totalRegistros" style="font-size:24px;font-weight:700;">0</div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="card">
    <div class="card-header bg-white py-3 d-flex flex-wrap align-items-center gap-3">
        <span class="fw-semibold flex-grow-1">Historial de Cotizaciones</span>
        <div class="btn-group btn-group-sm" Rol="group">
            <input type="search" id="searchCotizacion" class="form-control" placeholder="Buscar..." />
            <select id="estadoCotizacion" class="form-select form-select-sm">
                <option value="">Todos</option>
                <option value="0">Pendiente</option>
                <option value="1">Aprobada</option>
                <option value="2">Rechazada</option>
            </select>
        </div>
        <a href="/Comercial/App/CrearCotizacion" class="btn btn-primary">
            <i class="fa-solid fa-plus me-1"></i>Nueva Cotizacion
        </a>
    </div>
    <div class="card-body p-0">
        <div class="table-responsive">
            <table id="tableCotizaciones" class="table table-hover mb-0">
                <thead>
                    <tr>
                        <th class="ps-4">N°</th>
                        <th>Cliente</th>
                        <th>Ruta</th>
                        <th>Fecha Servicio</th>
                        <th>Valor</th>
                        <th>Estado</th>
                        <th>Creada</th>
                        <th class="text-end pe-4">Acciones</th>
                    </tr>
                </thead>
                <tbody></tbody>
            </table>
            <div id="emptyCotizaciones" class="text-center py-5 text-muted d-none">
                <i class="bi bi-inbox" style="font-size:40px;opacity:.3;">
                </i>
                <p class="mt-2 mb-0">
                    No hay cotizaciones que mostrar.
                </p>
            </div>
        </div>
    </div>
    <div class="card-footer bg-white">
        <div class="d-flex justify-content-between align-items-center">
            <div id="infoCotizaciones" class="text-muted">
            </div>
            <div id="paginationCotizaciones" class="btn-group">
            </div>
        </div>
    </div>
</div>

<!-- Modal Aprobar -->
<div class="modal fade" id="modalAprobar" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow">
            <form asp-action="Aprobar" method="post">
                <input type="hidden" id="aprobarId" name="id" />
                <div class="modal-header border-0 pb-0">
                    <h5 class="modal-title"><i class="bi bi-check-circle text-success me-2"></i>Aprobar Cotización</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Valor Aprobado</label>
                        <div class="input-group">
                            <span class="input-group-text">$</span>
                            <input type="number" id="aprobarValor" name="valorAprobado" class="form-control" step="0.01"
                                   min="0" placeholder="Dejar vacío para usar valor cotizado" />
                        </div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Observaciones</label>
                        <textarea name="observaciones" class="form-control" rows="3"
                                  placeholder="Observaciones sobre la aprobación…"></textarea>
                    </div>
                </div>
                <div class="modal-footer border-0 pt-0">
                    <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancelar</button>
                    <button type="submit" class="btn btn-success"><i class="bi bi-check-lg me-1"></i>Aprobar</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Modal Rechazar -->
<div class="modal fade" id="modalRechazar" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow">
            <form asp-action="Rechazar" method="post">
                <input type="hidden" id="rechazarId" name="id" />
                <div class="modal-header border-0 pb-0">
                    <h5 class="modal-title"><i class="bi bi-x-circle text-danger me-2"></i>Rechazar Cotización</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Motivo del rechazo <span
                            class="text-danger">*</span></label>
                            <textarea name="motivo" class="form-control" rows="3" required
                                      placeholder="Explique por qué se rechaza la cotización…"></textarea>
                        </div>
                    </div>
                    <div class="modal-footer border-0 pt-0">
                        <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancelar</button>
                        <button type="submit" class="btn btn-danger"><i class="bi bi-x-lg me-1"></i>Rechazar</button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    @section Scripts {
        <script>
            document.getElementById('modalAprobar').addEventListener('show.bs.modal', function (e) {
                var btn = e.relatedTarget;
                document.getElementById('aprobarId').value = btn.dataset.id;
                document.getElementById('aprobarValor').value = btn.dataset.valor;
            });

            document.getElementById('modalRechazar').addEventListener('show.bs.modal', function (e) {
                document.getElementById('rechazarId').value = e.relatedTarget.dataset.id;
            });

            function cargarDashboard() {
                $.ajax({
                    url: '/Comercial/Cotizacion/ObtenerDashboard',
                    type: 'GET',
                    success: function (response) {
                        if (!response.success)
                            return;

                        $("#totalPendientes").text(response.data.totalPendientes);
                        $("#totalAprobadas").text(response.data.totalAprobadas);
                        $("#totalRechazadas").text(response.data.totalRechazadas);
                        $("#totalRegistros").text(response.data.totalRegistros);
                    }
                });
            }

            const cotizacionesTable = new TableManager({
                url: '/Comercial/Cotizacion/ObtenerCotizaciones',
                tableId: '#tableCotizaciones',
                paginationId: '#paginationCotizaciones',
                infoId: '#infoCotizaciones',
                pageSize: 10,
                filters: {
                    search: '#searchCotizacion',
                    estado: '#estadoCotizacion'
                },
                beforeSend: () => showLoader(),
                onComplete: () => hideLoader(),
                renderTable: (data) => {

                    let tbody = $("#tableCotizaciones tbody");
                    tbody.empty();

                    if (!data || data.length === 0) {
                        $("#emptyCotizaciones").removeClass("d-none");
                        $("#tableCotizaciones").addClass("d-none");
                        return;
                    }

                    $("#emptyCotizaciones").addClass("d-none");
                    $("#tableCotizaciones").removeClass("d-none");

                    data.forEach(item => {

                        let badge = "secondary";

                        switch (item.estado) {

                            case "Pendiente":
                                badge = "warning";
                                break;

                            case "Aprobada":
                                badge = "success";
                                break;

                            case "Rechazada":
                                badge = "danger";
                                break;
                        }

                        let acciones = `
                                        <a
                                            href="/Comercial/Cotizaciones/Details/${item.idCotizacion}"
                                            class="btn btn-sm btn-outline-secondary">
                                            <i class="bi bi-eye"></i>
                                        </a>
                                        `;

                        if (item.estado === "Pendiente") {
                            acciones += `
                                        <a href="/Comercial/Cotizaciones/Edit/${item.idCotizacion}" class="btn btn-sm btn-outline-primary">
                                            <i class="bi bi-pencil"></i>
                                        </a>
                                        <button class="btn btn-sm btn-outline-success btn-aprobar" data-id="${item.idCotizacion}" data-valor="${item.valorCotizado}">
                                            <i class="bi bi-check-lg"></i>
                                        </button>
                                        <button class="btn btn-sm btn-outline-danger btn-rechazar" data-id="${item.idCotizacion}">
                                            <i class="bi bi-x-lg"></i>
                                        </button>
                                        `;
                        }

                        if (item.estado === "Aprobada" &&
                            !item.tieneServicio) {
                            acciones += `
                                        <a href="/Operaciones/Servicios/Create?cotizacionId=${item.idCotizacion}" class="btn btn-sm btn-primary">
                                            <i class="bi bi-truck me-1"></i>
                                            Servicio
                                        </a>
                                        `;
                        }

                        tbody.append(`
                                    <tr>
                                        <td class="ps-4 fw-semibold">
                                            #${item.idCotizacion}
                                        </td>
                                        <td>
                                            <div class="fw-semibold">
                                                ${item.cliente}
                                            </div>
                                            <small class="text-muted">
                                                ${item.correo ?? ''}
                                            </small>
                                        </td>
                                        <td>
                                            <small>
                                                ${item.origen}
                                                <i class="bi bi-arrow-right mx-1"></i>
                                                ${item.destino}
                                            </small>
                                        </td>
                                        <td>
                                            ${moment(item.fechaServicio).format("DD/MM/YYYY")}
                                        </td>
                                        <td class="fw-semibold">
                                            $${parseFloat(item.valorCotizado).toLocaleString('es-CO')}
                                        </td>
                                        <td>
                                            <span class="badge bg-${badge}">
                                                ${item.estado}
                                            </span>
                                        </td>
                                        <td>
                                            ${moment(item.fechaCreacion).format("DD/MM/YYYY")}
                                        </td>
                                        <td class="text-end pe-4">
                                            <div class="d-flex justify-content-end gap-1">
                                                ${acciones}
                                            </div>
                                        </td>
                                    </tr>
                                    `);
                    });
                }

            });

            $(document).on("click", ".btn-aprobar", function () {
                $("#aprobarId").val($(this).data("id"));
                $("#aprobarValor").val($(this).data("valor"));
                $("#modalAprobar").modal("show");
            });

            $(document).on("click", ".btn-rechazar", function () {
                $("#rechazarId").val($(this).data("id"));
                $("#modalRechazar").modal("show");
            });

            $(function () {
                cargarDashboard();
                cotizacionesTable.load();
            });
        </script>

    }
