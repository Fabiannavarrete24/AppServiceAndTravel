    <h4 class="mb-1 fw-bold">Cotización <span class="text-primary">#@Model.idCotizacion.ToString("D6")</span></h4>
    <span class="badge rounded-pill px-3 py-2 fs-6" style="@badgeCss">
      <i class="bi @badgeIcon me-1"></i>@Model.Estado
    </span>
  </div>
  <div class="d-flex gap-2 flex-wrap">
    <a asp-action="Index" class="btn btn-outline-secondary rounded-3">
      <i class="bi bi-arrow-left me-1"></i>Volver
