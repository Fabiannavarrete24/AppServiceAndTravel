@using AppServiceAndTravel.Areas.Admin.Models
@model ConfiguracionGeneral

@{
    ViewData["Title"] = "Configuración";
    ViewData["Breadcrumb"] = "Configuración del sistema";
}

<div class="row g-4">

    <!-- Configuración -->
    <div class="col-lg-8">

        <div class="card border-0 shadow-sm rounded-4">

            <div class="card-header bg-white border-0 pt-4 px-4 pb-0">
                <h5 class="fw-semibold mb-1">
                    <i class="bi bi-gear-fill text-primary me-2"></i>
                    Configuración general
                </h5>

                <small class="text-muted">
                    Personalice la información corporativa del sistema
                </small>
            </div>

            <div class="card-body p-4">

                <form asp-action="Index"
                      method="post"
                      enctype="multipart/form-data">

                    @Html.AntiForgeryToken()

                    <div asp-validation-summary="ModelOnly"
                         class="alert alert-danger"></div>

                    <div class="row g-4">

                        <div class="col-md-6">
                            <label asp-for="NombreEmpresa" class="form-label fw-semibold"></label>
                            <input asp-for="NombreEmpresa" class="form-control rounded-3" />
                            <span asp-validation-for="NombreEmpresa" class="text-danger small"></span>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="NitEmpresa" class="form-label fw-semibold"></label>
                            <input asp-for="NitEmpresa" class="form-control rounded-3" />
                        </div>

                        <div class="col-md-6">
                            <label asp-for="Telefono" class="form-label fw-semibold"></label>
                            <input asp-for="Telefono" class="form-control rounded-3" />
                        </div>

                        <div class="col-md-6">
                            <label asp-for="correo" class="form-label fw-semibold"></label>
                            <input asp-for="correo" class="form-control rounded-3" />
                        </div>

                        <div class="col-12">
                            <label asp-for="Direccion" class="form-label fw-semibold"></label>
                            <textarea asp-for="Direccion"
                                      class="form-control rounded-3"
                                      rows="3"></textarea>
                        </div>

                        <!-- Logo -->
                        <div class="col-md-6">

                            <label class="form-label fw-semibold">
                                Logo empresa
                            </label>

                            <input type="file"
                                   name="logo"
                                   class="form-control rounded-3"
                                   accept="image/*" />

                            @if (!string.IsNullOrEmpty(Model.RutaLogo))
                            {
                                <div class="mt-3">
                                    <img src="@Model.RutaLogo"
                                         class="img-fluid rounded shadow-sm"
                                         style="max-height:90px;" />
                                </div>
                            }

                        </div>

                        <!-- Favicon -->
                        <div class="col-md-6">

                            <label class="form-label fw-semibold">
                                Favicon
                            </label>

                            <input type="file"
                                   name="favicon"
                                   class="form-control rounded-3"
                                   accept=".ico" />

                            @if (!string.IsNullOrEmpty(Model.RutaFavicon))
                            {
                                <div class="mt-3">
                                    <img src="@Model.RutaFavicon"
                                         class="rounded shadow-sm"
                                         style="width:32px;height:32px;" />
                                </div>
                            }

                        </div>

                    </div>

                    <div class="d-flex gap-2 mt-4">

                        <button type="submit"
                                class="btn btn-primary px-4 rounded-3">

                            <i class="bi bi-save me-1"></i>
                            Guardar cambios

                        </button>

                    </div>

                </form>

            </div>

        </div>

    </div>

    <!-- Sidebar -->
    <div class="col-lg-4">

        <div class="card border-0 shadow-sm rounded-4">

            <div class="card-body p-4">

                <h6 class="fw-semibold mb-3">
                    <i class="bi bi-info-circle text-primary me-2"></i>
                    Información
                </h6>

                <div class="small text-muted">

                    <p>
                        Esta configuración se utilizará en:
                    </p>

                    <ul class="mb-0">
                        <li>PDFs y reportes</li>
                        <li>Correos automáticos</li>
                        <li>Login del sistema</li>
                        <li>Panel administrativo</li>
                    </ul>

                </div>

            </div>

        </div>

    </div>

</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}